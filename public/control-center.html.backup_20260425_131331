async function loadGitHistory(repo) {
    const el = document.getElementById('git-' + (repo === 'api' ? 'api' : 'website'));
    el.innerHTML = '<div style="text-align:center;padding:20px;color:var(--text2)"><div class="spinner"></div> Fetching from GitHub...</div>';

    const repoName = repo === 'api' ? 'slh-api' : 'osifeu-prog.github.io';
    try {
        const r = await fetch(GH_API + '/' + repoName + '/commits?per_page=30');
        const commits = await r.json();
        if (!Array.isArray(commits)) { el.innerHTML = '<div style="color:var(--red);padding:10px">Auth required or repo not found</div>'; return; }

        el.innerHTML = commits.map(c => {
            const date = new Date(c.commit.author.date).toLocaleDateString('he-IL');
            const msg = c.commit.message.split('\n')[0];
            const sha = c.sha.substring(0, 7);
            const type = msg.startsWith('feat') ? 'accent' : msg.startsWith('fix') ? 'gold' : msg.startsWith('docs') ? 'cyan' : 'text2';
            return `<div class="feed-item">
                <code style="color:var(--${type});font-size:11px;min-width:60px">${sha}</code>
                <div style="flex:1;font-size:11px">${msg.substring(0,80)}</div>
                <div class="feed-time">${date}</div>
            </div>`;
        }).join('');
    } catch(e) {
        el.innerHTML = '<div style="color:var(--red);padding:10px">' + e.message + '</div>';
    }
}

