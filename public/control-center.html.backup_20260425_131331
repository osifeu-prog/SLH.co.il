/* ===== API ENDPOINTS ===== */
async function testAllEndpoints() {
    const el = document.getElementById('api-results');
    el.innerHTML = '<div style="text-align:center;padding:20px;color:var(--gold)"><div class="spinner"></div> Testing all endpoints...</div>';
    try {
        const r = await fetch(API + '/openapi.json');
        const d = await r.json();
        const paths = Object.keys(d.paths).sort();
        let html = '<table class="cc-table"><thead><tr><th>Endpoint</th><th>Methods</th><th>Status</th></tr></thead><tbody>';
        let ok=0, fail=0, skip=0;
        for (const p of paths) {
            const methods = Object.keys(d.paths[p]).filter(m=>['get','post','delete','put','patch'].includes(m)).join(', ').toUpperCase();
            const hasGet = d.paths[p].get;
            let status;
            if (hasGet && !p.includes('{') && !p.includes('verify')) {
                try {
                    const key = localStorage.getItem('slh_admin_password') || '';
                    const tr = await fetch(API + p, { method: 'GET', headers: { 'X-Admin-Key': key } });
                    if (tr.ok) { status = `<span class="dot ok"></span> ${tr.status}`; ok++; }
                    else { status = `<span class="dot err"></span> ${tr.status}`; fail++; }
                } catch(e) { status = '<span class="dot err"></span> ERR'; fail++; }
            } else { status = '<span class="dot warn"></span> N/A'; skip++; }
            html += `<tr><td style="font-family:var(--mono);font-size:11px;direction:ltr;text-align:left">${p}</td><td style="font-size:10px">${methods}</td><td>${status}</td></tr>`;
        }
        html += '</tbody></table>';
        html = `<div style="margin-bottom:12px;font-size:12px"><span style="color:var(--accent)">${ok} OK</span> · <span style="color:var(--red)">${fail} Failed</span> · <span style="color:var(--gold)">${skip} Skipped</span> · <strong>${paths.length} Total</strong></div>` + html;
        el.innerHTML = html;
    } catch(e) {
        el.innerHTML = '<div style="color:var(--red);padding:10px">Error: ' + e.message + '</div>';
    }
}

