<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SLH Spark — Control Center</title>
    <meta name="robots" content="noindex, nofollow">
    <link rel="icon" type="image/png" href="/favicon-32.png">
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="/css/shared.css?v=20260425d">
    <style>
        :root{--bg:#05080f;--bg2:#0c1018;--bg3:#141924;--accent:#00ff41;--accent2:#39ff14;--cyan:#00e5ff;--gold:#ffd700;--red:#ff0055;--purple:#a855f7;--blue:#3b82f6;--orange:#f97316;--text:#e0e0f0;--text2:#6a6a90;--text3:#444466;--border:rgba(0,255,65,.1);--glow:0 0 20px rgba(0,255,65,.15);--font:'Inter',system-ui,sans-serif;--mono:'Space Mono',monospace;--radius:10px}
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:var(--font);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
        a{color:var(--accent);text-decoration:none}

        /* Animated BG Grid */
        body::before{content:'';position:fixed;inset:0;background:linear-gradient(rgba(0,255,65,.02) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,65,.02) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0;animation:gridShift 20s linear infinite}
        @keyframes gridShift{to{background-position:40px 40px}}

        .cc-wrapper{position:relative;z-index:1;max-width:1400px;margin:0 auto;padding:16px}

        /* Header */
        .cc-header{text-align:center;padding:24px 0 16px;position:relative}
        .cc-header h1{font-size:32px;font-weight:800;background:linear-gradient(135deg,var(--accent),var(--cyan),var(--purple));-webkit-background-clip:text;-webkit-text-fill-color:transparent;letter-spacing:-0.5px}
        .cc-header .sub{color:var(--text2);font-size:13px;margin-top:4px}
        .cc-live{display:inline-flex;align-items:center;gap:8px;margin-top:12px;padding:6px 16px;background:rgba(0,255,65,.06);border:1px solid rgba(0,255,65,.2);border-radius:20px;font-size:11px;color:var(--accent);font-weight:600}
        .cc-live .pulse{width:8px;height:8px;background:var(--accent);border-radius:50%;animation:pulse 2s infinite}
        @keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,255,65,.5)}50%{opacity:.4;box-shadow:0 0 0 8px transparent}}

        /* Tabs */
        .cc-tabs{display:flex;gap:4px;padding:8px 0 16px;overflow-x:auto;scrollbar-width:none}
        .cc-tabs::-webkit-scrollbar{display:none}
        .cc-tab{padding:8px 18px;background:var(--bg2);border:1px solid var(--border);border-radius:8px;font-size:12px;color:var(--text2);cursor:pointer;white-space:nowrap;transition:.2s;font-family:var(--font);font-weight:500}
        .cc-tab:hover{color:var(--text);border-color:rgba(0,255,65,.3)}
        .cc-tab.active{background:rgba(0,255,65,.08);color:var(--accent);border-color:rgba(0,255,65,.4);box-shadow:var(--glow)}
        .cc-tab i{margin-left:6px}

        /* Panels */
        .cc-panel{display:none}
        .cc-panel.active{display:block;animation:fadeIn .3s}
        @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

        /* Cards */
        .cc-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:20px;margin-bottom:16px}
        .cc-card h2{font-size:15px;color:var(--accent);margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
        .cc-card h2 .badge{font-size:10px;padding:3px 10px;border-radius:4px;font-weight:600}
        .badge-ok{background:rgba(0,255,65,.1);color:var(--accent)}
        .badge-warn{background:rgba(255,215,0,.1);color:var(--gold)}
        .badge-err{background:rgba(255,0,85,.1);color:var(--red)}
        .badge-info{background:rgba(0,229,255,.1);color:var(--cyan)}

        /* KPI Grid */
        .kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;margin-bottom:16px}
        .kpi{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:16px;position:relative;overflow:hidden;transition:.2s}
        .kpi:hover{border-color:rgba(0,255,65,.3);box-shadow:var(--glow)}
        .kpi::after{content:'';position:absolute;top:0;right:0;width:3px;height:100%;border-radius:0 8px 8px 0}
        .kpi.g::after{background:var(--accent)}.kpi.c::after{background:var(--cyan)}.kpi.y::after{background:var(--gold)}.kpi.r::after{background:var(--red)}.kpi.p::after{background:var(--purple)}.kpi.b::after{background:var(--blue)}.kpi.o::after{background:var(--orange)}
        .kpi-label{font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-bottom:6px}
        .kpi-val{font-size:28px;font-weight:700;color:#fff}
        .kpi-sub{font-size:10px;color:var(--text2);margin-top:4px}
        .kpi-icon{position:absolute;top:14px;left:14px;font-size:24px;opacity:.08}

        /* Tables */
        .cc-table{width:100%;border-collapse:collapse;font-size:12px}
        .cc-table th{text-align:right;padding:8px 12px;background:var(--bg3);color:var(--text2);font-size:10px;text-transform:uppercase;letter-spacing:1px;position:sticky;top:0}
        .cc-table td{padding:8px 12px;border-bottom:1px solid rgba(255,255,255,.04)}
        .cc-table tr:hover td{background:rgba(0,255,65,.02)}
        .dot{display:inline-block;width:8px;height:8px;border-radius:50%;margin-left:6px}
        .dot.ok{background:var(--accent)}.dot.warn{background:var(--gold)}.dot.err{background:var(--red)}.dot.off{background:var(--text3)}

        /* Progress bars */
        .prog-row{display:flex;align-items:center;gap:12px;margin-bottom:10px}
        .prog-label{width:160px;color:var(--text2);font-size:12px;flex-shrink:0}
        .prog-bar{flex:1;height:8px;background:var(--bg3);border-radius:4px;overflow:hidden}
        .prog-fill{height:100%;border-radius:4px;transition:width .6s ease}
        .prog-pct{width:45px;text-align:left;color:var(--text2);font-size:11px;font-weight:600}

        /* Timeline */
        .timeline{position:relative;padding-right:30px}
        .timeline::before{content:'';position:absolute;top:0;right:14px;width:2px;height:100%;background:var(--border)}
        .tl-item{position:relative;margin-bottom:20px;padding-right:30px}
        .tl-item::before{content:'';position:absolute;right:-3px;top:6px;width:12px;height:12px;border-radius:50%;background:var(--accent);border:2px solid var(--bg2);z-index:1}
        .tl-date{font-size:11px;color:var(--accent);font-weight:600;font-family:var(--mono)}
        .tl-title{font-size:14px;font-weight:600;color:#fff;margin:4px 0}
        .tl-body{font-size:12px;color:var(--text2);line-height:1.6}
        .tl-tags{display:flex;gap:4px;flex-wrap:wrap;margin-top:6px}
        .tl-tag{font-size:9px;padding:2px 8px;border-radius:3px;background:rgba(0,255,65,.08);color:var(--accent);border:1px solid rgba(0,255,65,.15)}

        /* Activity Feed */
        .feed-item{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid rgba(255,255,255,.03);font-size:12px;align-items:flex-start}
        .feed-icon{width:28px;height:28px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:12px;flex-shrink:0}
        .feed-icon.api{background:rgba(0,255,65,.1);color:var(--accent)}
        .feed-icon.git{background:rgba(168,85,247,.1);color:var(--purple)}
        .feed-icon.bot{background:rgba(0,229,255,.1);color:var(--cyan)}
        .feed-icon.sec{background:rgba(255,0,85,.1);color:var(--red)}
        .feed-icon.user{background:rgba(255,215,0,.1);color:var(--gold)}
        .feed-time{color:var(--text3);font-size:10px;font-family:var(--mono);min-width:50px;text-align:left}

        /* Btn */
        .cc-btn{background:var(--accent);color:#000;border:none;padding:7px 16px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:var(--font);transition:.2s}
        .cc-btn:hover{background:var(--accent2);box-shadow:0 0 12px rgba(0,255,65,.3)}
        .cc-btn.outline{background:transparent;color:var(--accent);border:1px solid rgba(0,255,65,.3)}
        .cc-btn.outline:hover{background:rgba(0,255,65,.06)}

        /* Grid layouts */
        .two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px}
        .three-col{display:grid;grid-template-columns:1fr 1fr 1fr;gap:16px}
        @media(max-width:1024px){.three-col{grid-template-columns:1fr 1fr}}
        @media(max-width:768px){.two-col,.three-col{grid-template-columns:1fr}.kpi-grid{grid-template-columns:repeat(2,1fr)}}

        /* Scrollable */
        .scroll-box{max-height:400px;overflow-y:auto;scrollbar-width:thin;scrollbar-color:var(--accent) var(--bg3)}
        .scroll-box::-webkit-scrollbar{width:4px}
        .scroll-box::-webkit-scrollbar-track{background:var(--bg3)}
        .scroll-box::-webkit-scrollbar-thumb{background:var(--accent);border-radius:2px}

        /* Version diff */
        .diff-add{color:var(--accent);background:rgba(0,255,65,.06);padding:1px 4px;border-radius:2px;font-family:var(--mono);font-size:11px}
        .diff-del{color:var(--red);background:rgba(255,0,85,.06);padding:1px 4px;border-radius:2px;font-family:var(--mono);font-size:11px;text-decoration:line-through}

        /* Loading spinner */
        .spinner{width:20px;height:20px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .6s linear infinite;display:inline-block}
        @keyframes spin{to{transform:rotate(360deg)}}

        /* Security panel */
        .sec-item{display:flex;gap:12px;padding:12px;background:var(--bg3);border-radius:8px;margin-bottom:8px;align-items:flex-start}
        .sec-severity{font-size:10px;font-weight:700;padding:3px 8px;border-radius:4px;min-width:50px;text-align:center}
        .sec-severity.critical{background:rgba(255,0,85,.15);color:var(--red)}
        .sec-severity.high{background:rgba(249,115,22,.15);color:var(--orange)}
        .sec-severity.medium{background:rgba(255,215,0,.15);color:var(--gold)}
        .sec-title{font-weight:600;font-size:13px;color:#fff}
        .sec-desc{font-size:11px;color:var(--text2);margin-top:2px}

        /* Architecture */
        .arch-node{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;background:var(--bg3);border:1px solid var(--border);border-radius:6px;font-size:11px;margin:4px}
        .arch-arrow{color:var(--accent);font-size:16px;margin:0 4px}
    </style>
</head>
<body>

<div id="topnav-root"></div>
<div id="ticker-root"></div>

<div class="cc-wrapper">
    <div class="cc-header">
        <h1><i class="fas fa-satellite-dish"></i> SLH Control Center</h1>
        <p class="sub">Real-time ecosystem monitoring · Session history · Version control · Security audit</p>
        <div class="cc-live"><span class="pulse"></span> LIVE · Auto-refresh 30s · <span id="cc-time"></span></div>
    </div>

    <!-- TABS -->
    <div class="cc-tabs">
        <div class="cc-tab active" data-tab="overview"><i class="fas fa-th-large"></i> Overview</div>
        <div class="cc-tab" data-tab="sessions"><i class="fas fa-history"></i> Session History</div>
        <div class="cc-tab" data-tab="versions"><i class="fas fa-code-branch"></i> Versions</div>
        <div class="cc-tab" data-tab="bots"><i class="fas fa-robot"></i> Bots (25)</div>
        <div class="cc-tab" data-tab="pages"><i class="fas fa-globe"></i> Pages (49)</div>
        <div class="cc-tab" data-tab="api"><i class="fas fa-server"></i> API</div>
        <div class="cc-tab" data-tab="security"><i class="fas fa-shield-alt"></i> Security</div>
        <div class="cc-tab" data-tab="tasks"><i class="fas fa-tasks"></i> Tasks</div>
    </div>

    <!-- ============ OVERVIEW ============ -->
    <div class="cc-panel active" id="panel-overview">
        <div class="kpi-grid" id="kpi-grid">
            <div class="kpi g"><i class="fas fa-heartbeat kpi-icon"></i><div class="kpi-label">API Status</div><div class="kpi-val" id="k-api">...</div><div class="kpi-sub" id="k-api-sub"></div></div>
            <div class="kpi c"><i class="fas fa-users kpi-icon"></i><div class="kpi-label">Total Users</div><div class="kpi-val" id="k-users">...</div><div class="kpi-sub" id="k-users-sub"></div></div>
            <div class="kpi y"><i class="fas fa-plug kpi-icon"></i><div class="kpi-label">API Endpoints</div><div class="kpi-val" id="k-endpoints">...</div><div class="kpi-sub">production</div></div>
            <div class="kpi p"><i class="fas fa-globe kpi-icon"></i><div class="kpi-label">HTML Pages</div><div class="kpi-val" id="k-pages">49</div><div class="kpi-sub">GitHub Pages</div></div>
            <div class="kpi b"><i class="fas fa-robot kpi-icon"></i><div class="kpi-label">Bots Running</div><div class="kpi-val" id="k-bots">25</div><div class="kpi-sub">Docker Compose</div></div>
            <div class="kpi o"><i class="fas fa-coins kpi-icon"></i><div class="kpi-label">Genesis Raised</div><div class="kpi-val" id="k-raised">...</div><div class="kpi-sub" id="k-raised-sub"></div></div>
            <div class="kpi g"><i class="fas fa-link kpi-icon"></i><div class="kpi-label">Audit Chain</div><div class="kpi-val" id="k-audit">...</div><div class="kpi-sub" id="k-audit-sub"></div></div>
            <div class="kpi r"><i class="fas fa-shield-alt kpi-icon"></i><div class="kpi-label">Security Issues</div><div class="kpi-val" id="k-sec">3</div><div class="kpi-sub">P0: 1 fixed, 2 remaining</div></div>
        </div>

        <div class="two-col">
            <div class="cc-card">
                <h2>Live Activity Feed <span class="badge badge-ok">Real-time</span></h2>
                <div class="scroll-box" id="activity-feed" style="max-height:320px">
                    <div style="text-align:center;padding:20px;color:var(--text2)"><div class="spinner"></div> Loading...</div>
                </div>
            </div>
            <div class="cc-card">
                <h2>System Coverage <button class="cc-btn outline" onclick="refreshCoverage()">Refresh</button></h2>
                <div id="coverage-bars">
                    <div class="prog-row"><div class="prog-label">shared.js loaded</div><div class="prog-bar"><div class="prog-fill" style="width:91%;background:var(--accent)"></div></div><div class="prog-pct">91%</div></div>
                    <div class="prog-row"><div class="prog-label">Theme switcher</div><div class="prog-bar"><div class="prog-fill" style="width:42%;background:var(--gold)"></div></div><div class="prog-pct">42%</div></div>
                    <div class="prog-row"><div class="prog-label">i18n translations</div><div class="prog-bar"><div class="prog-fill" style="width:37%;background:var(--cyan)"></div></div><div class="prog-pct">37%</div></div>
                    <div class="prog-row"><div class="prog-label">Analytics tracking</div><div class="prog-bar"><div class="prog-fill" style="width:100%;background:var(--accent)"></div></div><div class="prog-pct">100%</div></div>
                    <div class="prog-row"><div class="prog-label">AI Assistant</div><div class="prog-bar"><div class="prog-fill" style="width:42%;background:var(--purple)"></div></div><div class="prog-pct">42%</div></div>
                    <div class="prog-row"><div class="prog-label">OG Meta tags</div><div class="prog-bar"><div class="prog-fill" style="width:65%;background:var(--blue)"></div></div><div class="prog-pct">65%</div></div>
                    <div class="prog-row"><div class="prog-label">Security audit</div><div class="prog-bar"><div class="prog-fill" style="width:30%;background:var(--red)"></div></div><div class="prog-pct">30%</div></div>
                </div>
            </div>
        </div>

        <!-- Architecture -->
        <div class="cc-card">
            <h2>System Architecture</h2>
            <div style="text-align:center;padding:20px;direction:ltr">
                <div style="margin-bottom:12px">
                    <span class="arch-node"><i class="fas fa-user"></i> Users (16)</span>
                    <span class="arch-arrow"><i class="fas fa-arrow-left"></i></span>
                    <span class="arch-node" style="border-color:var(--cyan)"><i class="fas fa-globe"></i> slh-nft.com (49 pages)</span>
                    <span class="arch-arrow"><i class="fas fa-arrow-left"></i></span>
                    <span class="arch-node" style="border-color:var(--gold)"><i class="fas fa-server"></i> Railway API</span>
                </div>
                <div style="margin-bottom:12px">
                    <span class="arch-node"><i class="fab fa-telegram"></i> Telegram Users</span>
                    <span class="arch-arrow"><i class="fas fa-arrow-left"></i></span>
                    <span class="arch-node" style="border-color:var(--purple)"><i class="fas fa-robot"></i> 25 Bots (Docker)</span>
                    <span class="arch-arrow"><i class="fas fa-arrow-left"></i></span>
                    <span class="arch-node" style="border-color:var(--gold)"><i class="fas fa-server"></i> Railway API</span>
                </div>
                <div>
                    <span class="arch-node" style="border-color:var(--gold)"><i class="fas fa-server"></i> Railway API</span>
                    <span class="arch-arrow"><i class="fas fa-arrow-left"></i></span>
                    <span class="arch-node" style="border-color:var(--accent)"><i class="fas fa-database"></i> PostgreSQL</span>
                    <span class="arch-arrow">+</span>
                    <span class="arch-node" style="border-color:var(--red)"><i class="fas fa-bolt"></i> Redis</span>
                    <span class="arch-arrow">+</span>
                    <span class="arch-node" style="border-color:var(--orange)"><i class="fab fa-ethereum"></i> BSC Chain</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ============ SESSION HISTORY ============ -->
    <div class="cc-panel" id="panel-sessions">
        <div class="cc-card">
            <h2>Session Timeline <span class="badge badge-info" id="session-count">8 Sessions</span></h2>
            <div class="timeline" id="session-timeline">
                <!-- Populated by JS -->
            </div>
        </div>
    </div>

    <!-- ============ VERSIONS ============ -->
    <div class="cc-panel" id="panel-versions">
        <div class="two-col">
            <div class="cc-card">
                <h2>API Repository (slh-api) <button class="cc-btn outline" onclick="loadGitHistory('api')">Refresh</button></h2>
                <div class="scroll-box" id="git-api" style="max-height:500px">
                    <div style="text-align:center;padding:20px;color:var(--text2)"><div class="spinner"></div></div>
                </div>
            </div>
            <div class="cc-card">
                <h2>Website Repository <button class="cc-btn outline" onclick="loadGitHistory('website')">Refresh</button></h2>
                <div class="scroll-box" id="git-website" style="max-height:500px">
                    <div style="text-align:center;padding:20px;color:var(--text2)"><div class="spinner"></div></div>
                </div>
            </div>
        </div>
    </div>

    <!-- ============ BOTS ============ -->
    <div class="cc-panel" id="panel-bots">
        <div class="cc-card">
            <h2>Telegram Bots — 25 Services <span class="badge badge-ok" id="bots-badge">Loading...</span></h2>
            <div class="scroll-box" style="max-height:600px">
                <table class="cc-table" id="bots-table">
                    <thead><tr><th>Bot</th><th>Container</th><th>Status</th><th>Category</th><th>Notes</th></tr></thead>
                    <tbody id="bots-body"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ============ PAGES ============ -->
    <div class="cc-panel" id="panel-pages">
        <div class="cc-card">
            <h2>Website Pages — 49 HTML <button class="cc-btn" onclick="checkAllPages()">Check All Live</button></h2>
            <div class="scroll-box" style="max-height:600px">
                <table class="cc-table" id="pages-table">
                    <thead><tr><th>Page</th><th>Status</th><th>Nav</th><th>Theme</th><th>i18n</th><th>Analytics</th><th>AI</th></tr></thead>
                    <tbody id="pages-body"></tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ============ API ============ -->
    <div class="cc-panel" id="panel-api">
        <div class="cc-card">
            <h2>API Endpoints <button class="cc-btn" onclick="testAllEndpoints()">Test All</button></h2>
            <div class="scroll-box" id="api-results" style="max-height:600px">
                <div style="text-align:center;padding:20px;color:var(--text2)">Click "Test All" to check all endpoints</div>
            </div>
        </div>
    </div>

    <!-- ============ SECURITY ============ -->
    <div class="cc-panel" id="panel-security">
        <div class="cc-card">
            <h2>Security Audit <span class="badge badge-err" id="sec-badge">5 Issues</span></h2>
            <div id="security-list">
                <div class="sec-item"><div class="sec-severity critical" style="background:rgba(0,255,65,.15);color:var(--accent)">FIXED</div><div><div class="sec-title" style="text-decoration:line-through">Admin passwords in public HTML</div><div class="sec-desc">Session 12: Removed ADMIN_PASSWORDS array, deleted admin-test.html bypass, multi-admin system with hashed passwords deployed</div></div></div>
                <div class="sec-item"><div class="sec-severity critical">P0</div><div><div class="sec-title">Railway env vars missing</div><div class="sec-desc">JWT_SECRET is empty, ADMIN_API_KEYS using defaults — auth is broken</div></div></div>
                <div class="sec-item"><div class="sec-severity high">P1</div><div><div class="sec-title">31 bot tokens exposed</div><div class="sec-desc">All bot tokens were pasted in chat history. Need rotation via @BotFather</div></div></div>
