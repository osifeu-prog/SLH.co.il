          }
        ]
      }
    ];

    const lang = typeof getLang === 'function' ? getLang() : 'he';
    const t = (obj) => obj[lang] || obj.en || obj.he;

    const STATUS_TAG = {
      'completed': { cls: 'tag-done', he: 'הושלם', en: 'Done', ru: 'Готово', ar: 'مكتمل', fr: 'Terminé' },
      'in-progress': { cls: 'tag-wip', he: 'בביצוע', en: 'In Progress', ru: 'В процессе', ar: 'قيد التنفيذ', fr: 'En cours' },
      'upcoming': { cls: 'tag-soon', he: 'בקרוב', en: 'Soon', ru: 'Скоро', ar: 'قريباً', fr: 'Bientôt' },
      'future': { cls: 'tag-future', he: 'עתיד', en: 'Future', ru: 'Будущее', ar: 'المستقبل', fr: 'Futur' }
    };
    const CAT_LABELS = {
      infra: { he: 'תשתית', en: 'Infra', ru: 'Инфра', ar: 'بنية', fr: 'Infra' },
      token: { he: 'טוקן', en: 'Token', ru: 'Токен', ar: 'رمز', fr: 'Jeton' },
      bots: { he: 'בוטים', en: 'Bots', ru: 'Боты', ar: 'بوتات', fr: 'Bots' },
      finance: { he: 'פיננסים', en: 'Finance', ru: 'Финансы', ar: 'مالية', fr: 'Finance' },
      social: { he: 'קהילה', en: 'Social', ru: 'Соцсети', ar: 'اجتماعي', fr: 'Social' },
      ai: { he: 'AI', en: 'AI', ru: 'AI', ar: 'AI', fr: 'IA' },
      voice: { he: '📞 Voice', en: '📞 Voice', ru: '📞 Voice', ar: '📞 Voice', fr: '📞 Voice' },
      swarm: { he: '🛰️ Swarm', en: '🛰️ Swarm', ru: '🛰️ Swarm', ar: '🛰️ Swarm', fr: '🛰️ Swarm' }
    };

    // Count stats
    let completed = 0, inProgress = 0, upcoming = 0, total = 0;
    PHASES.forEach(p => p.items.forEach(i => {
      total++;
      if (i.status === 'completed') completed++;
      else if (i.status === 'in-progress') inProgress++;
      else upcoming++;
    }));

    document.getElementById('statCompleted').textContent = completed;
    document.getElementById('statInProgress').textContent = inProgress;
    document.getElementById('statUpcoming').textContent = upcoming + (total - completed - inProgress - upcoming);
    document.getElementById('statTotal').textContent = total;

    const pct = Math.round((completed / total) * 100);
    document.getElementById('progressPct').textContent = pct + '%';
    setTimeout(() => {
      document.getElementById('progressFill').style.width = pct + '%';
    }, 300);

    // Render timeline
    function renderTimeline(filter) {
      const container = document.getElementById('timeline');
      container.innerHTML = '';

      PHASES.forEach(phase => {
        const filtered = filter === 'all' ? phase.items : phase.items.filter(i => i.status === filter);
        if (filtered.length === 0) return;

        const phaseDiv = document.createElement('div');
        phaseDiv.className = 'timeline-phase';
        phaseDiv.innerHTML = `<div class="timeline-phase-title"><span>${t(phase.title)}</span></div>`;

        filtered.forEach((item, idx) => {
          const stag = STATUS_TAG[item.status];
          const ctag = CAT_LABELS[item.cat] || { he: item.cat, en: item.cat };
          const el = document.createElement('div');
          el.className = 'timeline-item';
          el.innerHTML = `
            <div class="timeline-dot ${item.status}"></div>
            <div class="timeline-card">
              <h3>${t(item.title)}</h3>
              <p>${t(item.desc)}</p>
              <div class="tags">
                <span class="tag ${stag.cls}">${stag[lang] || stag.en}</span>
                <span class="tag tag-cat">${t(ctag)}</span>
              </div>
            </div>
          `;
          phaseDiv.appendChild(el);
        });

        container.appendChild(phaseDiv);
      });
    }

    renderTimeline('all');

    // Filter buttons
    document.querySelectorAll('.roadmap-filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.roadmap-filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderTimeline(btn.dataset.filter);
      });
    });
  });
