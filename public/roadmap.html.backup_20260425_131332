            desc: { he: 'רשת ESP32 מבוזרת עם Proof-of-Location, ZVK rewards על heartbeat, multi-hop בקהילות ללא WiFi, marketplace scanning', en: 'Decentralized ESP32 network with Proof-of-Location, ZVK rewards per heartbeat, multi-hop mesh in offline communities', ru: 'Распределённая сеть ESP32 с Proof-of-Location и наградами ZVK', ar: 'شبكة ESP32 لامركزية مع Proof-of-Location ومكافآت ZVK', fr: 'Réseau ESP32 décentralisé avec Proof-of-Location et récompenses ZVK' }
          },
          { status: 'future', cat: 'swarm',
            title: { he: 'Kosher Wallet — ייצור המוני', en: 'Kosher Wallet — Mass Production', ru: 'Kosher Wallet — массовое производство', ar: 'Kosher Wallet — إنتاج شامل', fr: 'Kosher Wallet — Production de masse' },
