  <style>
    /* ===== Roadmap Page Styles ===== */

    .roadmap-hero {
      text-align: center;
      padding: 80px 20px 40px;
      position: relative;
      overflow: hidden;
    }
    .roadmap-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: radial-gradient(ellipse at 50% 0%, var(--accent)22 0%, transparent 70%);
      pointer-events: none;
    }
    .roadmap-hero h1 {
      font-size: 2.8rem;
      font-weight: 800;
      margin-bottom: 12px;
      background: linear-gradient(135deg, var(--accent), var(--text));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .roadmap-hero p {
      font-size: 1.15rem;
      color: var(--muted);
      max-width: 600px;
      margin: 0 auto;
    }

    /* Progress bar */
    .roadmap-progress {
      max-width: 700px;
      margin: 30px auto 10px;
      padding: 0 20px;
    }
    .roadmap-progress-bar {
      height: 8px;
      background: var(--card-bg);
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .roadmap-progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), #a855f7);
      border-radius: 4px;
      transition: width 1.5s ease;
    }
    .roadmap-progress-label {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 0.85rem;
      color: var(--muted);
    }

    /* Stats row */
    .roadmap-stats {
      display: flex;
      justify-content: center;
      gap: 40px;
      padding: 30px 20px;
      flex-wrap: wrap;
    }
    .roadmap-stat {
      text-align: center;
    }
    .roadmap-stat .num {
      font-size: 2.2rem;
      font-weight: 800;
      color: var(--accent);
    }
    .roadmap-stat .label {
      font-size: 0.85rem;
      color: var(--muted);
      margin-top: 4px;
    }

    /* Filter tabs */
    .roadmap-filters {
      display: flex;
      justify-content: center;
      gap: 10px;
      padding: 10px 20px 30px;
      flex-wrap: wrap;
    }
    .roadmap-filter-btn {
      padding: 8px 20px;
      border-radius: 20px;
      border: 1px solid var(--border);
      background: var(--card-bg);
      color: var(--text);
      cursor: pointer;
      font-size: 0.9rem;
      transition: all 0.3s;
    }
    .roadmap-filter-btn:hover, .roadmap-filter-btn.active {
      background: var(--accent);
      color: #fff;
      border-color: var(--accent);
    }

    /* Timeline */
    .timeline {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 20px 60px;
      position: relative;
    }
    .timeline::before {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: 3px;
      background: linear-gradient(to bottom, var(--accent), var(--border), transparent);
    }
    [dir="rtl"] .timeline::before { right: 50%; transform: translateX(50%); }
    [dir="ltr"] .timeline::before { left: 50%; transform: translateX(-50%); }

    .timeline-phase {
      margin-bottom: 60px;
    }
    .timeline-phase-title {
      text-align: center;
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--accent);
      margin-bottom: 30px;
      position: relative;
    }
    .timeline-phase-title span {
      background: var(--bg);
      padding: 0 20px;
      position: relative;
      z-index: 1;
    }

    .timeline-item {
      position: relative;
      width: 45%;
      padding: 0 0 20px;
    }
    .timeline-item:nth-child(odd) { margin-inline-start: 55%; }
    .timeline-item:nth-child(even) { margin-inline-end: 55%; text-align: end; }

    .timeline-dot {
      position: absolute;
      top: 8px;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--accent);
      border: 3px solid var(--bg);
      z-index: 2;
      box-shadow: 0 0 12px var(--accent)66;
    }
    .timeline-item:nth-child(odd) .timeline-dot {
      inset-inline-start: -8%;
      transform: translateX(-50%);
    }
    .timeline-item:nth-child(even) .timeline-dot {
      inset-inline-end: -8%;
      transform: translateX(50%);
    }

    .timeline-dot.completed { background: #22c55e; box-shadow: 0 0 12px #22c55e66; }
    .timeline-dot.in-progress { background: #f59e0b; box-shadow: 0 0 12px #f59e0b66; animation: pulse-dot 2s infinite; }
    .timeline-dot.upcoming { background: var(--muted); box-shadow: none; }

    @keyframes pulse-dot {
      0%, 100% { box-shadow: 0 0 12px #f59e0b66; }
      50% { box-shadow: 0 0 24px #f59e0baa; }
    }

    .timeline-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .timeline-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    }
    .timeline-card h3 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--text);
    }
    .timeline-card p {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.5;
      margin-bottom: 12px;
    }
    .timeline-card .tags {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }
    .timeline-item:nth-child(even) .tags { justify-content: flex-end; }

    .tag {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 10px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .tag-done { background: #22c55e22; color: #22c55e; }
    .tag-wip { background: #f59e0b22; color: #f59e0b; }
    .tag-soon { background: #3b82f622; color: #3b82f6; }
    .tag-future { background: #a855f722; color: #a855f7; }
    .tag-cat { background: var(--accent)18; color: var(--accent); }

    /* Responsive */
    @media (max-width: 768px) {
      .timeline::before {
        right: unset !important; left: 20px !important; transform: none !important;
      }
      .timeline-item,
      .timeline-item:nth-child(odd),
      .timeline-item:nth-child(even) {
        width: calc(100% - 50px);
        margin-inline-start: 50px !important;
        margin-inline-end: 0 !important;
        text-align: start !important;
      }
      .timeline-item:nth-child(odd) .timeline-dot,
      .timeline-item:nth-child(even) .timeline-dot {
        inset-inline-start: -42px;
        inset-inline-end: unset;
        transform: none;
      }
      .timeline-item:nth-child(even) .tags { justify-content: flex-start; }
      .roadmap-hero h1 { font-size: 2rem; }
      .roadmap-stats { gap: 20px; }
    }

    /* Vision section */
    .vision-section {
      max-width: 900px;
      margin: 0 auto 60px;
      padding: 0 20px;
    }
    .vision-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }
    .vision-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 24px;
      text-align: center;
      transition: transform 0.3s;
    }
    .vision-card:hover { transform: translateY(-4px); }
    .vision-card .icon {
      font-size: 2.5rem;
      margin-bottom: 12px;
      background: linear-gradient(135deg, var(--accent), #a855f7);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .vision-card h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; }
    .vision-card p { font-size: 0.88rem; color: var(--muted); line-height: 1.5; }

    /* CTA */
    .roadmap-cta {
      text-align: center;
      padding: 60px 20px;
      background: linear-gradient(180deg, transparent, var(--accent)08);
    }
    .roadmap-cta h2 { font-size: 1.8rem; font-weight: 800; margin-bottom: 12px; }
    .roadmap-cta p { color: var(--muted); margin-bottom: 24px; max-width: 500px; margin-inline: auto; }
    .cta-buttons { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
    .cta-buttons a {
      padding: 12px 30px;
      border-radius: 8px;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s;
    }
    .btn-primary-cta { background: var(--accent); color: #fff; }
    .btn-primary-cta:hover { filter: brightness(1.15); transform: translateY(-2px); }
    .btn-secondary-cta { border: 1px solid var(--border); color: var(--text); background: var(--card-bg); }
    .btn-secondary-cta:hover { border-color: var(--accent); color: var(--accent); }
  </style>
</head>
