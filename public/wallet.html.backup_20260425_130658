    <script src="https://unpkg.com/@tonconnect/ui@2/dist/tonconnect-ui.min.js"></script>
    <script src="/js/translations.js?v=20260421a"></script>
    <script src="/js/shared.js?v=20260421a"></script>
    <script src="/js/web3-wallet.js?v=20260421a"></script>
    <script src="/js/web3.js?v=20260421a"></script>
    <script>
    /* ── Wallet Constants ── */
    const WALLET_API = 'https://slh-api-production.up.railway.app/api/wallet';
    const BSC_CONTRACT_ADDR = '0xACb0A09414CEA1C879c67bB7A877E4e19480f022';
    const TON_WALLET_ADDR   = 'UQCr743gEr_nqV_0SBkSp3CtYS_15R3LDLBvLmKeEv7XdGvp';
    const FALLBACK_SLH_PRICE = 444;

    let slhPriceILS = FALLBACK_SLH_PRICE;
    let apiOnline = false;

    /* ── Wallet API fetch helper ── */
    async function walletFetch(endpoint) {
        try {
            const res = await fetch(`${WALLET_API}${endpoint}`, {
                headers: { 'Content-Type': 'application/json' }
            });
            if (!res.ok) throw new Error(`${res.status} ${res.statusText}`);
            return await res.json();
        } catch (err) {
            console.warn('[Wallet API]', endpoint, err.message);
            return null;
        }
    }

    /* ── API Status Indicator ── */
    function setApiStatus(online) {
        apiOnline = online;
        const el = document.getElementById('api-status');
        if (!el) return;
        if (online) {
            el.className = 'api-status online';
            el.innerHTML = '<i class="fas fa-circle" style="font-size:8px"></i> Live';
        } else {
            el.className = 'api-status offline';
            el.innerHTML = '<i class="fas fa-circle" style="font-size:8px"></i> Offline';
        }
    }

    /* ── Panel Switch ── */
    function switchPanel(panel) {
        document.querySelectorAll('.action-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.action-panel').forEach(p => p.classList.remove('active'));
        document.querySelector(`.action-tab[data-panel="${panel}"]`).classList.add('active');
        document.getElementById(`panel-${panel}`).classList.add('active');
    }

    /* ── Load SLH Price from API ── */
    async function loadPrice() {
        const data = await walletFetch('/price');
        if (data && data.price_ils != null) {
            slhPriceILS = data.price_ils;
            setApiStatus(true);
        } else {
            slhPriceILS = FALLBACK_SLH_PRICE;
        }
        const priceEl = document.getElementById('slh-price-display');
        if (priceEl) priceEl.textContent = `Price: ${formatNumber(slhPriceILS)} ILS`;
        return !!data;
    }

    /* ── Load Balances ── */
    // Uses /api/user/{id} because it includes TON_available/locked + SLH + ZVK
    // in a single response. /api/wallet/{id}/balances only has SLH+ZVK.
    async function loadBalances() {
        const user = getCurrentUser();
        if (!user) return;

        let data = null;
        try {
            const res = await fetch(`${WALLET_API.replace('/api/wallet','')}/api/user/${user.id}`, {
                headers: { 'Content-Type': 'application/json' }
            });
            if (res.ok) data = await res.json();
        } catch (err) {
            console.warn('[Wallet API] user endpoint', err.message);
        }

        if (data && data.balances) {
            setApiStatus(true);

            const bag = data.balances;
            const slh  = parseFloat(bag.SLH || 0);
            const zvk  = parseFloat(bag.ZVK || 0);
            const ton  = parseFloat(bag.TON_available || bag.TON || 0);
            const tonL = parseFloat(bag.TON_locked || bag.TON_LOCKED || 0);
            // BNB is on-chain only — shown in Web3 panel when user connects MetaMask
            const bnb  = parseFloat(bag.BNB || 0);

            document.getElementById('bal-slh').textContent        = formatNumber(slh);
            document.getElementById('bal-zvk').textContent        = formatNumber(zvk);
            document.getElementById('bal-ton').textContent         = formatNumber(ton);
            document.getElementById('bal-bnb').textContent         = formatNumber(bnb);
            document.getElementById('bal-ton-locked').textContent  = formatNumber(tonL);

            // Fiat equivalents
            document.getElementById('bal-slh-fiat').textContent =
                slh > 0 ? `~ ${formatNumber(slh * slhPriceILS)} ILS` : t('wallet_available');
            document.getElementById('bal-zvk-fiat').textContent     = t('wallet_game_rewards') || 'Game Rewards';
            document.getElementById('bal-ton-fiat').textContent     = t('wallet_available');
            document.getElementById('bal-bnb-fiat').textContent     = bnb > 0 ? t('wallet_available') : 'Connect MetaMask ↑';
            document.getElementById('bal-ton-locked-fiat').textContent = t('wallet_locked');
        } else {
            // Fallback: zeroes when API is down
            setApiStatus(false);
            ['bal-slh', 'bal-zvk', 'bal-ton', 'bal-bnb', 'bal-ton-locked'].forEach(id => {
                const el = document.getElementById(id);
                if (el) el.textContent = '0.00';
            });
        }
    }

    /* ── Load Deposit Addresses + QR Codes ── */
    async function loadAddresses() {
        const user = getCurrentUser();
        if (!user) return;

        const data = await walletFetch(`/${user.id}`);

        const tonAddr = (data && (data.ton_address || data.deposit_address_ton)) || TON_WALLET_ADDR;
        const bscAddr = (data && (data.bsc_address || data.deposit_address_bsc)) || BSC_CONTRACT_ADDR;

        document.getElementById('addr-ton').textContent = tonAddr;
        document.getElementById('addr-bsc').textContent = bscAddr;

        // Generate QR codes via qrserver.com (privacy-safe: only public addresses are sent)
        generateQrCodes(tonAddr, bscAddr);
    }

    /* ── QR Code Generation ──
       Uses qrserver.com API (free, no key, public addresses only).
       URI schemes follow standards:
       - TON: ton://transfer/{address}
       - BSC (EIP-681): ethereum:{address}@56 */
    function generateQrCodes(tonAddr, bscAddr) {
        const tonUri = 'ton://transfer/' + tonAddr;
        const bscUri = 'ethereum:' + bscAddr + '@56';
        const qrBase = 'https://api.qrserver.com/v1/create-qr-code/?size=400x400&margin=2&format=png&data=';

        const tonImg = document.getElementById('qr-img-ton');
        const bscImg = document.getElementById('qr-img-bsc');
        if (tonImg) tonImg.src = qrBase + encodeURIComponent(tonUri);
        if (bscImg) bscImg.src = qrBase + encodeURIComponent(bscAddr);

        // Deep links to popular apps
        const tonkeeper = document.getElementById('tonkeeper-link');
        const tonscan = document.getElementById('tonscan-link');
        const metamask = document.getElementById('metamask-link');
        const bscscan = document.getElementById('bscscan-link');
        if (tonkeeper) tonkeeper.href = tonUri;
        if (tonscan) tonscan.href = 'https://tonscan.org/address/' + tonAddr;
        if (metamask) metamask.href = 'https://metamask.app.link/send/' + bscAddr + '@56';
        if (bscscan) bscscan.href = 'https://bscscan.com/address/' + bscAddr;
    }

    /* ── Switch QR Network Display ── */
    window.showQr = function(network) {
        document.getElementById('qr-block-ton').style.display = network === 'ton' ? 'block' : 'none';
        document.getElementById('qr-block-bsc').style.display = network === 'bsc' ? 'block' : 'none';
        const tonBtn = document.getElementById('qr-btn-ton');
        const bscBtn = document.getElementById('qr-btn-bsc');
        if (tonBtn) tonBtn.classList.toggle('active', network === 'ton');
        if (bscBtn) bscBtn.classList.toggle('active', network === 'bsc');
    };

    /* ── Send ── */
    async function handleSend(e) {
        e.preventDefault();
        const toVal    = document.getElementById('send-to').value.trim();
        const amount   = parseFloat(document.getElementById('send-amount').value);
        const currency = document.getElementById('send-currency').value;
        const user     = getCurrentUser();

        if (!toVal || !amount || amount <= 0) {
            showToast(t('common_error'), true);
            return;
        }

        const result = await apiPost('/api/wallet/send', {
            from_id: user.id,
            to: toVal,
            amount,
            currency
        });

        if (result && result.success) {
            showToast(t('common_success'));
            document.getElementById('send-to').value = '';
            document.getElementById('send-amount').value = '';
            loadBalances();
            loadTransactions();
        } else {
            showToast(result?.error || t('common_error'), true);
        }
    }

    /* ── Load Transactions ── */
    async function loadTransactions() {
        const user = getCurrentUser();
        if (!user) return;

        const raw = await walletFetch(`/${user.id}/transactions`);
        const tbody = document.getElementById('tx-body');

        // Normalize: API may return array or { transactions: [] }
        const txList = Array.isArray(raw) ? raw
                     : (raw?.transactions || raw?.items || []);

        if (!txList.length) {
            tbody.innerHTML = `<tr><td colspan="5" style="text-align:center;padding:40px;color:var(--text3)">
                <i class="fas fa-inbox" style="font-size:32px;opacity:.4;display:block;margin-bottom:8px"></i>
                <span data-i18n="wallet_no_tx">${t('wallet_no_tx') || 'No transactions yet'}</span>
            </td></tr>`;
            return;
        }

        tbody.innerHTML = txList.map(tx => {
            const isIn = tx.type === 'receive' || tx.type === 'deposit' || tx.type === 'in';
            const typeClass = isIn ? 'tx-type-in' : 'tx-type-out';
            const arrow = isIn ? '+' : '-';
            const statusBadge = (tx.status === 'completed' || tx.status === 'confirmed')
                ? '<span class="badge badge-green">OK</span>'
                : `<span class="badge">${tx.status || 'Pending'}</span>`;
            const dateStr = tx.date || tx.created_at || tx.timestamp;

            return `<tr>
                <td class="${typeClass}"><i class="fas fa-arrow-${isIn ? 'down' : 'up'}"></i> ${tx.type}</td>
                <td class="${typeClass}">${arrow}${formatNumber(tx.amount)} ${tx.currency || tx.token || ''}</td>
                <td>${tx.counterparty || tx.from || tx.to || '-'}</td>
                <td>${dateStr ? timeAgo(dateStr) : '-'}</td>
                <td>${statusBadge}</td>
            </tr>`;
        }).join('');
    }

    /* ── Init ── */
    initShared({ activePage: 'wallet', requireAuth: true, requireRegistered: true, showBottomNav: true });

    // Web3 wallet connect buttons
    if (typeof renderWalletConnectButtons === 'function') {
      renderWalletConnectButtons('wallet-connect-section');
    }

    // Update BSCScan link + timestamp whenever web3 balances render
    (function hookWeb3Updates(){
      const updateExtras = () => {
        const last = window.__slh_web3_last;
        if (!last || !last.address) return;
        const bscLink = document.getElementById('web3-bscscan-link');
        if (bscLink) bscLink.href = `https://bscscan.com/address/${last.address}`;
        const ts = document.getElementById('web3-last-updated');
        if (ts) ts.textContent = 'עודכן: ' + new Date(last.at).toLocaleTimeString('he-IL');
      };
      // Poll every 5s — __slh_web3_last is set by renderWeb3Balances
      setInterval(updateExtras, 5000);
      updateExtras();
    })();

    // ============================================================
    // EXTERNAL WALLETS — Bybit / Binance / Bitget / OKX / Self
    // ============================================================
    async function loadExternalWallets() {
        const user = getCurrentUser();
        if (!user) return;
        const listEl = document.getElementById('ext-wallets-list');
        if (!listEl) return;

        try {
            const res = await fetch(`${WALLET_API.replace('/api/wallet','')}/api/external-wallets/${user.id}`);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const data = await res.json();

            if (!data.wallets || data.wallets.length === 0) {
                listEl.innerHTML = `
                    <div style="text-align:center;color:var(--text2);padding:24px;border:1px dashed rgba(255,255,255,0.1);border-radius:10px;font-size:13px">
                        <div style="font-size:32px;margin-bottom:8px">🪙</div>
                        עדיין לא הוספת ארנקים חיצוניים<br>
                        <span style="font-size:11px">לחץ "הוסף ארנק חיצוני" כדי להתחיל</span>
                    </div>`;
                document.getElementById('ext-total').style.display = 'none';
                return;
            }

            const providerIcons = {bybit:'🟠', binance:'🟡', bitget:'🔵', okx:'⚫', kucoin:'🟢', self:'🛡️'};
            const networkColors = {TON:'#0098ea', BSC:'#f3ba2f', ETH:'#627eea', BTC:'#f7931a'};

            let totalUsd = 0;
            listEl.innerHTML = data.wallets.map(w => {
                const icon = providerIcons[w.provider] || '🛡️';
                const color = networkColors[w.network] || '#888';
                const native = parseFloat(w.last_balance_native || 0);
                totalUsd += parseFloat(w.last_balance_usdt || 0);
                const lastChecked = w.last_checked ? new Date(w.last_checked).toLocaleString('he-IL') : 'אף פעם';
                const shortAddr = w.address.length > 20 ? w.address.slice(0,8) + '...' + w.address.slice(-6) : w.address;
                return `
                    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-right:3px solid ${color};border-radius:10px;padding:14px 16px">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
                            <div style="font-weight:800;color:#fff;font-size:14px">${icon} ${w.label}</div>
                            <button onclick="deleteExternalWallet(${w.id})" style="background:transparent;border:1px solid rgba(239,68,68,0.3);color:#ef4444;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11px">🗑️ הסר</button>
                        </div>
                        <div style="font-family:monospace;font-size:11px;color:var(--text2);margin-bottom:8px;direction:ltr;text-align:left">${shortAddr}</div>
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                            <span style="font-size:11px;color:${color};font-weight:700;text-transform:uppercase">${w.network}</span>
                            <span style="font-size:18px;font-weight:900;color:#fff">${native.toFixed(4)}</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center">
                            <span style="font-size:10px;color:var(--text3)">עודכן: ${lastChecked}</span>
                            <button onclick="refreshExternalWallet(${w.id})" style="background:rgba(0,188,212,0.1);color:#00bcd4;border:1px solid rgba(0,188,212,0.3);padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11px">🔄 רענן</button>
                        </div>
                    </div>`;
            }).join('');

            const totalEl = document.getElementById('ext-total');
            const totalValEl = document.getElementById('ext-total-value');
            const totalIlsEl = document.getElementById('ext-total-ils');
            if (totalEl) totalEl.style.display = totalUsd > 0 ? 'block' : 'none';
            if (totalValEl) totalValEl.textContent = '$' + totalUsd.toFixed(2);
            if (totalIlsEl) totalIlsEl.textContent = '≈ ₪' + (totalUsd * 3.65).toFixed(2);
        } catch (err) {
            console.warn('[ExtWallets] Error:', err);
            listEl.innerHTML = `<div style="color:#ef4444;padding:14px;font-size:13px">⚠️ שגיאה בטעינת הארנקים</div>`;
        }
    }

    function openAddExternalWalletModal() {
        document.getElementById('ext-wallet-modal').style.display = 'flex';
        document.getElementById('ext-label').value = '';
        document.getElementById('ext-address').value = '';
        document.getElementById('ext-network').value = 'TON';
        document.getElementById('ext-provider').value = 'self';
    }

    function closeExternalWalletModal() {
        document.getElementById('ext-wallet-modal').style.display = 'none';
    }

    async function saveExternalWallet() {
        const user = getCurrentUser();
        if (!user) return showToast('יש להתחבר תחילה', true);
        const label = document.getElementById('ext-label').value.trim();
        const network = document.getElementById('ext-network').value;
        const provider = document.getElementById('ext-provider').value;
        const address = document.getElementById('ext-address').value.trim();
        if (!label) return showToast('תן תווית לארנק', true);
        if (!address || address.length < 10) return showToast('כתובת לא תקינה', true);
        try {
            const res = await fetch(`${WALLET_API.replace('/api/wallet','')}/api/external-wallets/add`, {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({user_id: user.id, label, network, provider, address})
            });
            const data = await res.json();
            if (!res.ok || !data.ok) throw new Error(data.detail || 'Failed');
            showToast('✅ נוסף! טוען יתרה...');
            closeExternalWalletModal();
            // Refresh balance immediately
            await fetch(`${WALLET_API.replace('/api/wallet','')}/api/external-wallets/refresh/${data.wallet_id}`, {method: 'POST'});
            await loadExternalWallets();
        } catch (err) {
            showToast('שגיאה: ' + err.message, true);
        }
    }

    async function deleteExternalWallet(walletId) {
        if (!confirm('להסיר את הארנק הזה?')) return;
        const user = getCurrentUser();
        if (!user) return;
        try {
            await fetch(`${WALLET_API.replace('/api/wallet','')}/api/external-wallets/${walletId}?user_id=${user.id}`, {method: 'DELETE'});
            showToast('הוסר');
            await loadExternalWallets();
        } catch(e) { showToast('שגיאה', true); }
    }

    async function refreshExternalWallet(walletId) {
        try {
            showToast('🔄 מרענן יתרה...');
            await fetch(`${WALLET_API.replace('/api/wallet','')}/api/external-wallets/refresh/${walletId}`, {method: 'POST'});
            await loadExternalWallets();
        } catch(e) { showToast('שגיאה', true); }
    }

    // ============================================================
    // CEX PORTFOLIO — Bybit + Binance API Keys (READ-ONLY)
    // ============================================================
    const CEX_API = WALLET_API.replace('/api/wallet','');

    async function loadCexPortfolio() {
        const user = getCurrentUser();
        if (!user) return;
        const keysEl = document.getElementById('cex-keys-list');
        const breakdownEl = document.getElementById('cex-breakdown');
        const summaryEl = document.getElementById('cex-portfolio-summary');
        if (!keysEl) return;

        try {
            // 1) List all keys for this user
            const keysRes = await fetch(`${CEX_API}/api/cex/keys/${user.id}`);
            const keysData = await keysRes.json();
            const keys = keysData.keys || [];

            if (keys.length === 0) {
                keysEl.innerHTML = `
                    <div style="text-align:center;color:var(--text2);padding:20px;border:1px dashed rgba(255,215,0,0.2);border-radius:10px;font-size:13px">
                        <div style="font-size:32px;margin-bottom:8px">🔐</div>
                        עדיין לא חיברת API Keys<br>
                        <span style="font-size:11px">חבר Bybit / Binance לראות את כל הנכסים שלך</span>
                    </div>`;
                breakdownEl.innerHTML = '';
                summaryEl.style.display = 'none';
                return;
            }

            keysEl.innerHTML = keys.map(k => {
                const emoji = k.exchange === 'bybit' ? '🟠' : '🟡';
                const lastUsed = k.last_used_at ? new Date(k.last_used_at).toLocaleString('he-IL') : 'אף פעם';
                const errBadge = k.last_error ? `<span style="color:#ef4444;font-size:10px">⚠️ ${k.last_error.substring(0,40)}</span>` : '';
                return `
                    <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,215,0,0.2);border-right:3px solid #ffd700;border-radius:10px;padding:14px 16px">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
                            <div style="font-weight:800;color:#fff;font-size:14px">${emoji} ${k.label}</div>
                            <div style="display:flex;gap:6px">
                                <button onclick="syncCexKey(${k.id})" style="background:rgba(0,188,212,0.1);color:#00bcd4;border:1px solid rgba(0,188,212,0.3);padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11px">🔄 סנכרן</button>
                                <button onclick="deleteCexKey(${k.id})" style="background:transparent;border:1px solid rgba(239,68,68,0.3);color:#ef4444;padding:4px 10px;border-radius:6px;cursor:pointer;font-size:11px">🗑️</button>
                            </div>
                        </div>
                        <div style="font-family:monospace;font-size:11px;color:var(--text2);direction:ltr;text-align:left;margin-bottom:4px">${k.api_key_masked}</div>
                        <div style="font-size:10px;color:var(--text3)">סנכרון אחרון: ${lastUsed}</div>
                        ${errBadge}
                    </div>`;
            }).join('');

            // 2) Fetch consolidated portfolio
            const portRes = await fetch(`${CEX_API}/api/cex/portfolio/${user.id}`);
            const port = await portRes.json();

            if (port.total_usd > 0 || port.exchanges?.length) {
                summaryEl.style.display = 'block';
                document.getElementById('cex-total-usd').textContent = '$' + (port.total_usd || 0).toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
                document.getElementById('cex-total-ils').textContent = '≈ ₪' + (port.total_ils || 0).toLocaleString('he-IL', {minimumFractionDigits:2, maximumFractionDigits:2});
                const lastSync = port.exchanges?.length ? port.exchanges[0].snapshot_at : null;
                document.getElementById('cex-last-sync').textContent = lastSync ? 'עודכן: ' + new Date(lastSync).toLocaleString('he-IL') : 'לא סונכרן';
            } else {
                summaryEl.style.display = 'none';
            }

            // 3) Render breakdown per exchange
            if (!port.exchanges || port.exchanges.length === 0) {
                breakdownEl.innerHTML = '';
                return;
            }
            breakdownEl.innerHTML = port.exchanges.map(ex => {
                let balances = ex.spot_balances || {};
                if (typeof balances === 'string') { try { balances = JSON.parse(balances); } catch(e) { balances = {}; } }
                const entries = Object.entries(balances).sort((a,b)=>(b[1].usd_value||0)-(a[1].usd_value||0));
                const emoji = ex.exchange === 'bybit' ? '🟠' : '🟡';
                return `
                    <div style="margin-top:14px;padding:14px;background:rgba(0,0,0,0.3);border-radius:10px;border:1px solid rgba(255,255,255,0.08)">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
                            <h4 style="color:#ffd700;font-size:14px;margin:0">${emoji} ${ex.exchange.toUpperCase()}</h4>
                            <div style="font-weight:800;color:#22c55e;font-size:15px">$${(ex.total_usd || 0).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}</div>
                        </div>
                        ${entries.length ? `
                            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:8px">
                                ${entries.map(([sym, b]) => {
                                    const balance = b.balance || ((b.free || 0) + (b.locked || 0));
                                    const usd = b.usd_value || 0;
                                    return `
                                        <div style="background:rgba(255,255,255,0.04);padding:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.06)">
                                            <div style="font-weight:800;color:#fff;font-size:13px">${sym}</div>
                                            <div style="font-size:12px;color:var(--text2);direction:ltr">${Number(balance).toLocaleString('en-US',{maximumFractionDigits:8})}</div>
                                            ${usd > 0 ? `<div style="font-size:11px;color:#22c55e">$${usd.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2})}</div>` : ''}
                                        </div>`;
                                }).join('')}
                            </div>
                        ` : `<div style="color:var(--text3);font-size:12px;text-align:center;padding:14px">אין יתרות — לחץ סנכרן לטעינה</div>`}
                    </div>`;
            }).join('');
        } catch (err) {
            console.warn('[CEX] Error:', err);
            keysEl.innerHTML = `<div style="color:#ef4444;padding:14px;font-size:13px">⚠️ שגיאה: ${err.message}</div>`;
        }
    }

    function openAddCexKeyModal() {
        document.getElementById('cex-key-modal').style.display = 'flex';
        document.getElementById('cex-label').value = '';
        document.getElementById('cex-api-key').value = '';
        document.getElementById('cex-api-secret').value = '';
    }
    function closeAddCexKeyModal() {
        document.getElementById('cex-key-modal').style.display = 'none';
    }

    async function saveCexKey() {
        const user = getCurrentUser();
        if (!user) return showToast('יש להתחבר תחילה', true);
        const exchange = document.getElementById('cex-exchange').value;
        const label = document.getElementById('cex-label').value.trim();
        const api_key = document.getElementById('cex-api-key').value.trim();
        const api_secret = document.getElementById('cex-api-secret').value.trim();
        if (!label) return showToast('תן תווית', true);
        if (api_key.length < 8) return showToast('API Key קצר מדי', true);
        if (api_secret.length < 8) return showToast('Secret קצר מדי', true);

        try {
            const res = await fetch(`${CEX_API}/api/cex/add-key`, {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({
                    user_id: user.id,
                    exchange,
                    label,
                    api_key,
                    api_secret,
                    permissions: ['read']
                })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.detail || 'Failed');
            showToast('✅ נחבר! טוען יתרות...');
            closeAddCexKeyModal();
            // Immediate sync to load balances
            if (data.key_id) {
                await fetch(`${CEX_API}/api/cex/sync/${data.key_id}`, {method: 'POST'});
            }
            await loadCexPortfolio();
        } catch (err) {
            showToast('שגיאה: ' + err.message, true);
        }
    }

    async function syncCexKey(keyId) {
        showToast('🔄 מסנכרן...');
        try {
            const res = await fetch(`${CEX_API}/api/cex/sync/${keyId}`, {method: 'POST'});
            const data = await res.json();
            if (data.ok) {
                showToast(`✅ סונכרן — ${data.assets_count || 0} נכסים, $${(data.total_usd || 0).toFixed(2)}`);
            } else {
                showToast(`⚠️ ${data.error || 'Sync failed'}`, true);
            }
            await loadCexPortfolio();
        } catch (err) {
            showToast('שגיאה: ' + err.message, true);
        }
    }

    async function syncAllCexKeys() {
        const user = getCurrentUser();
        if (!user) return;
        const keysRes = await fetch(`${CEX_API}/api/cex/keys/${user.id}`);
        const keysData = await keysRes.json();
        for (const k of (keysData.keys || [])) {
            try { await fetch(`${CEX_API}/api/cex/sync/${k.id}`, {method: 'POST'}); } catch(e) {}
        }
        showToast('✅ כל המפתחות סונכרנו');
        await loadCexPortfolio();
    }

    async function deleteCexKey(keyId) {
        if (!confirm('להסיר את ה-API Key?')) return;
        const user = getCurrentUser();
        if (!user) return;
        try {
            await fetch(`${CEX_API}/api/cex/keys/${keyId}?user_id=${user.id}`, {method: 'DELETE'});
            showToast('הוסר');
            await loadCexPortfolio();
        } catch(e) { showToast('שגיאה', true); }
    }

    // Load everything in parallel
    Promise.all([
        loadPrice(),
        loadBalances(),
        loadAddresses(),
        loadTransactions(),
        loadExternalWallets(),
        loadCexPortfolio()
    ]).then(() => {
        console.log('[Wallet] Init complete, API:', apiOnline ? 'online' : 'offline');
    });
    </script>
