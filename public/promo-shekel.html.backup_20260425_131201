}

/* Path picker — 4 funnels */
.paths-section {
  max-width: 1200px; margin: 30px auto 50px; padding: 0 20px;
}
.paths-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 16px;
}
.path-card {
  background: var(--bg2);
  border: 2px solid var(--border);
  border-radius: 20px;
  padding: 26px 22px;
  position: relative;
  cursor: pointer;
  transition: all .25s;
  display: flex; flex-direction: column;
  text-decoration: none; color: var(--text);
}
.path-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 50px rgba(0,0,0,.4);
}
.path-card.buyer { border-color: var(--gold); }
.path-card.buyer:hover { box-shadow: 0 20px 50px rgba(255,215,0,.3); }
.path-card.partner { border-color: var(--green); }
.path-card.partner:hover { box-shadow: 0 20px 50px rgba(0,232,135,.3); }
.path-card.genesis { border-color: var(--purple); }
.path-card.genesis:hover { box-shadow: 0 20px 50px rgba(168,85,247,.3); }
.path-card.community { border-color: var(--blue); }
.path-card.community:hover { box-shadow: 0 20px 50px rgba(59,130,246,.3); }

.path-icon {
  width: 56px; height: 56px;
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 28px;
  margin-bottom: 14px;
}
.path-card.buyer .path-icon { background: rgba(255,215,0,.15); color: var(--gold); }
.path-card.partner .path-icon { background: rgba(0,232,135,.15); color: var(--green); }
.path-card.genesis .path-icon { background: rgba(168,85,247,.15); color: var(--purple); }
