<style>
:root {
  --bg: #050810;
  --bg2: #0d1220;
  --bg3: #151a2e;
  --gold: #ffd700;
  --gold2: #f3ba2f;
  --green: #00e887;
  --green2: #00ff9f;
  --red: #ff4444;
  --purple: #a855f7;
  --blue: #3b82f6;
  --text: #f5f5f8;
  --text2: #9ba0b5;
  --text3: #5a6078;
  --border: rgba(255,215,0,.2);
  --glow-gold: 0 0 40px rgba(255,215,0,.4);
  --glow-green: 0 0 40px rgba(0,232,135,.35);
}

*{box-sizing:border-box}
body{
  background: var(--bg);
  color: var(--text);
  font-family: 'Rubik','Inter',-apple-system,system-ui,sans-serif;
  margin:0; min-height:100vh;
  line-height:1.6;
  overflow-x:hidden;
}
[lang="en"] body, [lang="fr"] body, [lang="ru"] body { font-family:'Inter','Rubik',sans-serif; direction:ltr }
[lang="ar"] body { direction:rtl; text-align:right }

/* === ARTISTIC BACKGROUND — multi-layer canvas === */
.bg-fx {
  position:fixed; inset:0; z-index:-1; overflow:hidden; pointer-events:none;
}
/* Layer 1: deep cosmic gradient */
.bg-fx::before {
  content:''; position:absolute; inset:0;
  background:
    radial-gradient(ellipse at 20% 10%, rgba(255,215,0,.18), transparent 45%),
    radial-gradient(ellipse at 85% 80%, rgba(0,232,135,.15), transparent 50%),
    radial-gradient(circle at 50% 50%, rgba(168,85,247,.10), transparent 65%),
    radial-gradient(circle at 10% 90%, rgba(59,130,246,.08), transparent 50%),
    linear-gradient(180deg, #050810 0%, #0a0e1f 50%, #050810 100%);
}
/* Layer 2: dot mesh + grid (fine art texture) */
.bg-fx::after {
  content:''; position:absolute; inset:-50%;
  background-image:
    radial-gradient(circle at 50% 50%, rgba(255,215,0,.4) 0.8px, transparent 1.5px),
    linear-gradient(rgba(255,215,0,.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,232,135,.025) 1px, transparent 1px);
  background-size: 40px 40px, 80px 80px, 80px 80px;
  animation: gridMove 60s linear infinite;
  opacity: 0.7;
}
@keyframes gridMove {
  to { transform: translate(80px, 80px); }
}

/* Layer 3: floating orbs (parallax depth) */
.orb {
  position: fixed; border-radius: 50%; pointer-events: none; z-index: -1;
  filter: blur(80px); opacity: 0.5;
  animation: floatOrb 20s ease-in-out infinite alternate;
}
.orb-1 { top: 5%; left: 10%; width: 320px; height: 320px; background: radial-gradient(circle, var(--gold), transparent 70%); }
.orb-2 { top: 50%; right: 5%; width: 280px; height: 280px; background: radial-gradient(circle, var(--green), transparent 70%); animation-delay: -7s; }
.orb-3 { bottom: 10%; left: 30%; width: 260px; height: 260px; background: radial-gradient(circle, var(--purple), transparent 70%); animation-delay: -14s; }
@keyframes floatOrb {
  from { transform: translate(0,0) scale(1); }
  to   { transform: translate(40px, -40px) scale(1.1); }
}

/* Coin shower — RISING UP with size variety */
.coin {
  position: fixed; pointer-events: none; z-index: -1;
  opacity: 0;
  bottom: -10vh;
  animation: coinRise linear infinite;
  filter: drop-shadow(0 0 8px currentColor);
  will-change: transform, opacity;
}
.coin.tiny    { font-size: 14px; opacity: 0.25; }
.coin.small   { font-size: 20px; opacity: 0.4; }
.coin.medium  { font-size: 28px; opacity: 0.5; }
.coin.large   { font-size: 38px; opacity: 0.55; }
.coin.huge    { font-size: 52px; opacity: 0.4; }
.coin.gold-glow   { color: var(--gold); }
.coin.green-glow  { color: var(--green); }
.coin.blue-glow   { color: var(--blue); }
.coin.purple-glow { color: var(--purple); }
@keyframes coinRise {
  0%   { transform: translateY(0) translateX(0) rotate(0deg); }
  25%  { transform: translateY(-30vh) translateX(15px) rotate(90deg); }
  50%  { transform: translateY(-55vh) translateX(-10px) rotate(180deg); }
  75%  { transform: translateY(-85vh) translateX(20px) rotate(360deg); }
  100% { transform: translateY(-120vh) translateX(0) rotate(540deg); }
}
@keyframes coinRiseFast {
  0% { transform: translateY(0) rotate(0); opacity: 0; }
  20% { opacity: var(--coin-opacity, 0.4); }
  100% { transform: translateY(-130vh) rotate(720deg); opacity: 0; }
}
@keyframes coinFloat {
  0% { transform: translateY(0) translateX(0) rotate(0); opacity: 0; }
  10%, 90% { opacity: var(--coin-opacity, 0.4); }
  100% { transform: translateY(-115vh) translateX(calc(var(--drift,0) * 1px)) rotate(360deg); opacity: 0; }
}

/* Hero: artistic title treatment */
.hero h1 {
  position: relative;
  text-shadow: 0 0 40px rgba(255,215,0,.3);
}
.hero h1::after {
  content: '';
  display: block;
  width: 100px; height: 4px;
  margin: 24px auto 0;
  background: linear-gradient(90deg, transparent, var(--gold), var(--green), transparent);
  border-radius: 2px;
  animation: lineShimmer 3s ease-in-out infinite;
}
@keyframes lineShimmer {
  0%, 100% { width: 60px; opacity: 0.6; }
  50%      { width: 180px; opacity: 1; }
}

/* === FX LIVE CHART === */
.fx-chart-section {
  max-width: 1100px; margin: 0 auto 50px; padding: 0 20px;
}
.fx-chart-card {
  background: linear-gradient(135deg, rgba(0,232,135,.06), rgba(255,215,0,.03));
  border: 1px solid rgba(0,232,135,.3);
  border-radius: 24px;
  padding: 28px;
  position: relative;
  overflow: hidden;
}
.fx-chart-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--green), transparent);
}
.fx-chart-head {
  display: flex; justify-content: space-between; align-items: flex-start;
  margin-bottom: 20px; flex-wrap: wrap; gap: 16px;
}
.fx-chart-title {
  font-size: 22px; font-weight: 900;
  margin: 0 0 4px;
  background: linear-gradient(135deg, var(--green), var(--gold));
  -webkit-background-clip: text; background-clip: text; color: transparent;
}
.fx-chart-sub { font-size: 13px; color: var(--text2); }
.fx-current {
  text-align: center;
  padding: 10px 18px;
  background: var(--bg);
  border: 1px solid var(--green);
  border-radius: 14px;
}
.fx-current .now { font-size: 28px; font-weight: 900; color: var(--green); line-height: 1; }
.fx-current .lbl { font-size: 11px; color: var(--text2); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 4px; }
.fx-chart-canvas {
  background: rgba(0,0,0,.3);
  border-radius: 14px;
  padding: 12px;
  height: 240px;
  position: relative;
}
#fx-chart {
  width: 100%; height: 100%; display: block;
}
.fx-legend {
  display: flex; gap: 20px; justify-content: center;
  margin-top: 14px;
  font-size: 12px; color: var(--text2);
}
.fx-legend span {
  display: inline-flex; align-items: center; gap: 6px;
}
.fx-legend i {
  width: 10px; height: 10px; border-radius: 50%; display: inline-block;
}

/* Hero */
.hero {
  max-width: 1200px; margin: 0 auto; padding: 60px 20px 30px;
  text-align: center; position: relative;
}
.urgent-badge {
  display: inline-flex; align-items: center; gap: 10px;
  padding: 10px 22px;
  background: linear-gradient(135deg, rgba(255,68,68,.2), rgba(255,215,0,.15));
  border: 1px solid var(--red);
  border-radius: 32px;
  font-size: 13px; font-weight: 800;
  text-transform: uppercase; letter-spacing: 2px;
  color: #ff8080;
  margin-bottom: 20px;
  animation: badgePulse 2s infinite;
}
@keyframes badgePulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(255,68,68,.4); }
  50% { box-shadow: 0 0 0 14px rgba(255,68,68,0); }
}
.urgent-badge .dot {
  width:10px; height:10px; background:var(--red);
  border-radius:50%; animation: blink 1s infinite;
}
@keyframes blink { 50% {opacity:.3} }

.hero h1 {
  font-size: clamp(32px, 6vw, 72px);
  font-weight: 900; line-height: 1.1;
  margin: 0 0 18px;
  background: linear-gradient(135deg, #fff 0%, var(--gold) 40%, var(--green) 100%);
  -webkit-background-clip: text; background-clip: text;
  color: transparent;
}
.hero .tagline {
  font-size: clamp(16px, 2.5vw, 22px);
  color: var(--text);
  max-width: 720px; margin: 0 auto 12px;
  font-weight: 600;
}
.hero .sub {
  font-size: 15px; color: var(--text2);
  max-width: 600px; margin: 0 auto 32px;
}

/* === RIVER FULL-SCREEN ANIMATION === */
.river {
  position: fixed; inset: 0; z-index: -1; pointer-events: none;
  overflow: hidden;
}
.river::before {
  content: '';
  position: absolute;
  width: 200%; height: 100%;
  top: 0; left: -50%;
  background:
    linear-gradient(90deg,
      transparent 0%,
      rgba(0, 232, 135, 0.04) 20%,
      rgba(255, 215, 0, 0.06) 50%,
      rgba(0, 232, 135, 0.04) 80%,
      transparent 100%
    );
  animation: flowRight 15s linear infinite;
}
.river::after {
  content: '';
  position: absolute;
  width: 200%; height: 100%;
  bottom: 0; left: -50%;
  background: repeating-linear-gradient(
    -45deg,
    transparent 0 60px,
    rgba(0, 232, 135, 0.02) 60px 62px,
    transparent 62px 120px,
    rgba(255, 215, 0, 0.02) 120px 122px
  );
  animation: flowLeft 40s linear infinite;
}
@keyframes flowRight {
  from { transform: translateX(-50%); }
  to   { transform: translateX(0%); }
}
@keyframes flowLeft {
  from { transform: translateX(0%); }
  to   { transform: translateX(-50%); }
}

/* River particles (shekel → dollar flow) */
.river-particle {
  position: fixed; z-index: -1;
  font-size: 20px; opacity: 0;
  pointer-events: none;
  animation: flowParticle linear infinite;
}
@keyframes flowParticle {
  0%   { transform: translate(-5vw, 0) scale(0.8); opacity: 0; }
  10%  { opacity: 0.35; }
  90%  { opacity: 0.35; }
  100% { transform: translate(110vw, -20px) scale(1.2); opacity: 0; }
}

