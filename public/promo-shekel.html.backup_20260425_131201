function getHebrewDate() {
  try {
    const now = new Date();
    const hebrew = new Intl.DateTimeFormat('he-IL-u-ca-hebrew', {
      weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
    }).format(now);
    const greg = new Intl.DateTimeFormat('he-IL', {
      weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
    }).format(now);
    const time = now.toLocaleTimeString('he-IL', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    return `📅 ${hebrew} · ${greg} · ${time}`;
  } catch(e) {
    return new Date().toLocaleString('he-IL');
  }
}
function updateHebrewDate() {
  const el = document.getElementById('hebrew-date');
  if(el) el.textContent = getHebrewDate();
}
