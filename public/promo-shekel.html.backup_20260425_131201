/* === DIVERSE COIN SHOWER — sizes, colors, paths, emojis === */
(() => {
  const shower = document.getElementById('coin-shower');
  if (!shower) return;

  // Rich emoji mix: money, israeli, crypto, growth
  const emojiSets = {
    common:  ['💰', '🪙', '💎', '₪', '💸', '$', '📈'],
    israeli: ['🇮🇱', '✡️', '🕊️'],
    crypto:  ['₿', '⚡', '🔷', '🟡'],
    growth:  ['🌱', '🌿', '✨', '🌟', '🚀', '🎯']
  };
  const allEmojis = [...emojiSets.common, ...emojiSets.common, ...emojiSets.crypto, ...emojiSets.israeli, ...emojiSets.growth];

  const sizes  = ['tiny', 'small', 'medium', 'large', 'huge'];
  const colors = ['gold-glow', 'green-glow', 'gold-glow', 'blue-glow', 'gold-glow', 'purple-glow'];
  const anims  = ['coinRise', 'coinFloat', 'coinRiseFast'];

  function spawn() {
    const c = document.createElement('div');
    const sizeClass = sizes[Math.floor(Math.random() * sizes.length)];
    const colorClass = colors[Math.floor(Math.random() * colors.length)];
    c.className = `coin ${sizeClass} ${colorClass}`;
    c.textContent = allEmojis[Math.floor(Math.random() * allEmojis.length)];
    c.style.left = Math.random() * 100 + 'vw';
    const dur = 12 + Math.random() * 22;
    const anim = anims[Math.floor(Math.random() * anims.length)];
    c.style.animation = `${anim} ${dur}s linear`;
    c.style.setProperty('--drift', (Math.random() * 200 - 100));
    shower.appendChild(c);
    // Remove after animation completes
    setTimeout(() => c.remove(), dur * 1000 + 200);
  }

  // Initial burst — 18 staggered
  for (let i = 0; i < 18; i++) {
    setTimeout(spawn, i * 700 + Math.random() * 400);
  }

  // Continuous spawn — every 1.2-2.8 seconds, paused if tab hidden
  let spawnInterval;
  function startSpawning() {
    if (spawnInterval) return;
    spawnInterval = setInterval(() => {
      if (!document.hidden) spawn();
    }, 1500 + Math.random() * 1300);
  }
  function stopSpawning() {
    if (spawnInterval) { clearInterval(spawnInterval); spawnInterval = null; }
  }
  startSpawning();
  document.addEventListener('visibilitychange', () => {
    document.hidden ? stopSpawning() : startSpawning();
  });

  // Adapt to scroll position — more coins when in offer/payment sections
  let lastScrollSpawn = 0;
  window.addEventListener('scroll', () => {
    const now = Date.now();
    if (now - lastScrollSpawn < 800) return;
    const scrolled = window.scrollY / (document.body.scrollHeight - window.innerHeight);
    // Burst more in the paying section (60-80% scroll)
    if (scrolled > 0.55 && scrolled < 0.85 && Math.random() > 0.4) {
      spawn();
      lastScrollSpawn = now;
    }
  });
})();

