async function switchFXCurrency(cur) {
  currentFXCurrency = cur;
  document.querySelectorAll('.fx-tab').forEach(t => {
    const isActive = t.dataset.cur === cur;
    t.style.background = isActive ? 'var(--gold)' : 'var(--bg2)';
    t.style.color = isActive ? '#000' : 'var(--text2)';
    t.style.border = isActive ? 'none' : '1px solid var(--border)';
  });
  await loadFX();
}

async function loadFX() {
  const cur = currentFXCurrency;
  const today = new Date();
  const past = new Date(today); past.setMonth(today.getMonth() - 6);
  const fmt = d => d.toISOString().slice(0,10);

  try {
    // Try Frankfurter API first (free, reliable, no key)
    let r, data;
    try {
      r = await fetch(`https://api.frankfurter.dev/v1/${fmt(past)}..${fmt(today)}?base=ILS&symbols=${cur === 'BTC' ? 'USD' : cur}`);
      const fr = await r.json();
      if (fr.rates) {
        // Convert frankfurter shape to exchangerate.host shape
        data = { rates: {} };
        for (const date in fr.rates) {
          data.rates[date] = fr.rates[date];
        }
      }
    } catch(e) { console.log('frankfurter failed, trying exchangerate.host'); }

    if (!data || !data.rates) {
      r = await fetch(`https://api.exchangerate.host/timeseries?start_date=${fmt(past)}&end_date=${fmt(today)}&base=ILS&symbols=${cur === 'BTC' ? 'USD' : cur}`);
      data = await r.json();
    }
    if (data && data.rates) {
      const entries = Object.entries(data.rates).sort();
      const sampled = entries.filter((_, i) => i % 4 === 0);
      const targetSym = cur === 'BTC' ? 'USD' : cur;
      const values = sampled.map(([d, v]) => v[targetSym]);

      if (cur === 'BTC') {
        // For BTC: convert ILS->USD->BTC using fixed BTC price ~$67000
        const btcPrice = 67000;
        const btcValues = values.map(v => v / btcPrice);
        renderFXChart(btcValues, null);
        const latest = btcValues[btcValues.length - 1];
        document.getElementById('fx-live-rate').textContent = (latest * 1e8).toFixed(0) + ' sat';
      } else {
        renderFXChart(values, null);
        const latest = values[values.length - 1];
        const sym = FX_CURRENCY_SYMBOLS[cur] || '';
        document.getElementById('fx-live-rate').textContent = sym + latest.toFixed(3);
        if (cur === 'USD') document.getElementById('fx-usd').textContent = (1 / latest).toFixed(2);
        const start = values[0];
        const change = ((latest - start) / start * 100).toFixed(1);
        const lbl = document.getElementById('fx-delta-label');
        if (lbl) {
          const isUp = change > 0;
          lbl.textContent = (isUp ? '⬆ +' : '⬇ ') + change + '% ב-6 חודשים';
          lbl.style.color = isUp ? 'var(--green)' : 'var(--red)';
        }
      }
      return;
    }
  } catch (e) { console.log('FX fetch failed, using fallback', e); }

  // Fallback
  const values = FX_FALLBACKS[cur] || FX_FALLBACKS.USD;
  renderFXChart(values, null);
  const latest = values[values.length - 1];
  const sym = FX_CURRENCY_SYMBOLS[cur] || '';
  document.getElementById('fx-live-rate').textContent = cur === 'BTC' ? (latest * 1e8).toFixed(0) + ' sat' : sym + latest.toFixed(3);
}
window.switchFXCurrency = switchFXCurrency;

function renderFXChart(values, dates) {
  const canvas = document.getElementById('fx-chart');
  if (!canvas || !values || values.length < 2) return;
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  const rect = canvas.getBoundingClientRect();
  canvas.width = rect.width * dpr;
  canvas.height = rect.height * dpr;
  ctx.scale(dpr, dpr);

  const W = rect.width, H = rect.height;
  const PAD = 20;
  const min = Math.min(...values) * 0.995;
  const max = Math.max(...values) * 1.005;
  const range = max - min;

  // Background gradient
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, 'rgba(0,232,135,0.25)');
  grad.addColorStop(1, 'rgba(0,232,135,0)');

  // Grid lines
  ctx.strokeStyle = 'rgba(255,255,255,0.05)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = PAD + (H - 2*PAD) * (i/4);
    ctx.beginPath(); ctx.moveTo(PAD, y); ctx.lineTo(W-PAD, y); ctx.stroke();
  }

  // Value points
  const xStep = (W - 2*PAD) / (values.length - 1);
  const points = values.map((v, i) => ({
    x: PAD + i * xStep,
    y: PAD + (H - 2*PAD) * (1 - (v - min) / range)
  }));

  // Area fill
  ctx.beginPath();
  ctx.moveTo(points[0].x, H - PAD);
  points.forEach(p => ctx.lineTo(p.x, p.y));
  ctx.lineTo(points[points.length-1].x, H - PAD);
  ctx.closePath();
  ctx.fillStyle = grad;
  ctx.fill();

  // Line
  ctx.beginPath();
  points.forEach((p, i) => i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y));
  ctx.strokeStyle = '#00e887';
  ctx.lineWidth = 2.5;
  ctx.stroke();

  // Glow effect
  ctx.shadowColor = '#00e887';
  ctx.shadowBlur = 14;
  ctx.stroke();
  ctx.shadowBlur = 0;

  // Last point highlight
  const last = points[points.length - 1];
  ctx.beginPath();
  ctx.arc(last.x, last.y, 6, 0, Math.PI * 2);
  ctx.fillStyle = '#ffd700';
  ctx.fill();
  ctx.beginPath();
  ctx.arc(last.x, last.y, 3, 0, Math.PI * 2);
  ctx.fillStyle = '#fff';
  ctx.fill();

  // Value label at end
  ctx.font = 'bold 12px Rubik, sans-serif';
  ctx.fillStyle = '#ffd700';
  ctx.textAlign = 'right';
  ctx.fillText('$' + values[values.length-1].toFixed(3), W - PAD, last.y - 12);

  // Start label
  ctx.fillStyle = 'rgba(255,255,255,0.5)';
  ctx.textAlign = 'left';
  ctx.font = '11px Rubik, sans-serif';
  ctx.fillText('$' + values[0].toFixed(3) + ' (לפני 6ח)', PAD + 4, points[0].y + 16);
}

