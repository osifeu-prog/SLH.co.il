/* Theme transition smooth */
html, body, .why-card, .path-card, .pay-method-card,
.offer-card, .pay-card, .stake-card, .preorder-card,
.eco-link, .faq-item, .countdown-unit, .fx-card {
  transition: background-color .4s ease, border-color .4s ease, color .4s ease, box-shadow .4s ease;
}

.theme-menu {
  position: fixed; top: 14px; inset-inline-start: 14px; z-index: 100;
  display: flex; flex-direction: column; gap: 6px;
  background: rgba(13,18,32,.9);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 8px;
  backdrop-filter: blur(10px);
}
.theme-menu.collapsed .theme-items { display: none; }
.theme-toggle {
  display: flex; align-items: center; gap: 8px;
  background: transparent; border: none; color: var(--text);
  padding: 6px 10px;
  font-size: 13px; font-weight: 700;
  cursor: pointer; border-radius: 8px;
  font-family: inherit;
}
.theme-items {
  display: flex; flex-direction: column; gap: 4px;
}
.theme-btn {
  display: flex; align-items: center; gap: 8px;
  background: transparent; border: 1px solid transparent; color: var(--text2);
  padding: 8px 12px;
  font-size: 12px; font-weight: 600;
  cursor: pointer; border-radius: 8px;
  font-family: inherit;
  text-align: start;
}
.theme-btn:hover { background: rgba(255,215,0,.1); color: var(--text); }
.theme-btn.active { background: var(--gold); color: #000; border-color: var(--gold); }
.theme-btn .swatch {
  width: 16px; height: 16px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,.2);
}

/* Custom color picker */
.theme-custom {
  display: none;
  flex-direction: column; gap: 6px;
  padding: 8px;
  border-top: 1px solid var(--border);
