/* === THEME SYSTEM === */
function applyTheme(name) {
  if (name === 'default') {
    document.documentElement.removeAttribute('data-theme');
  } else {
    document.documentElement.setAttribute('data-theme', name);
  }
  document.querySelectorAll('.theme-btn[data-theme]').forEach(b =>
    b.classList.toggle('active', b.dataset.theme === name));
  try { localStorage.setItem('slh_promo_theme', name); } catch(e) {}
  // Clear any custom overrides
  ['--bg', '--text', '--gold', '--green', '--purple'].forEach(v =>
    document.documentElement.style.removeProperty(v));
  // Hide custom panel
  document.getElementById('theme-menu').classList.remove('show-custom');
}

function setCustomColor(prop, value) {
  document.documentElement.style.setProperty(prop, value);
  // Mark custom as "in use"
  document.querySelectorAll('.theme-btn[data-theme]').forEach(b => b.classList.remove('active'));
  try {
    const custom = JSON.parse(localStorage.getItem('slh_promo_custom') || '{}');
    custom[prop] = value;
    localStorage.setItem('slh_promo_custom', JSON.stringify(custom));
  } catch(e) {}
}

function toggleCustom() {
  document.getElementById('theme-menu').classList.toggle('show-custom');
}

function resetCustom() {
  ['--bg', '--text', '--gold', '--green', '--purple'].forEach(v =>
    document.documentElement.style.removeProperty(v));
  try { localStorage.removeItem('slh_promo_custom'); } catch(e) {}
  applyTheme('default');
}

function toggleThemeMenu() {
  document.getElementById('theme-menu').classList.toggle('collapsed');
}

/* Restore saved theme on load */
(() => {
  try {
    const saved = localStorage.getItem('slh_promo_theme');
    if (saved && saved !== 'default') {
      applyTheme(saved);
    }
    const custom = JSON.parse(localStorage.getItem('slh_promo_custom') || '{}');
    Object.entries(custom).forEach(([prop, val]) => {
      document.documentElement.style.setProperty(prop, val);
      const input = document.querySelector(`[data-prop="${prop}"]`);
      if (input) input.value = val;
    });
  } catch(e) {}
})();

