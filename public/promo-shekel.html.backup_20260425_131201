/* === AUTO PAGE-VIEW TRACKING (CRITICAL — was missing!) === */
(function trackPageView() {
  try {
    const urlParams = new URLSearchParams(location.search);
    const fbclid = urlParams.get('fbclid');
    const utm_source = urlParams.get('utm_source');
    const referrer = document.referrer;

    let source = 'direct';
    if (fbclid) source = 'facebook';
    else if (utm_source) source = utm_source;
    else if (referrer.includes('t.me') || referrer.includes('telegram')) source = 'telegram';
    else if (referrer.includes('whatsapp') || referrer.includes('wa.me')) source = 'whatsapp';
    else if (referrer.includes('instagram')) source = 'instagram';
    else if (referrer.includes('youtube')) source = 'youtube';
    else if (referrer) source = new URL(referrer).hostname;

    fetch('https://slh-api-production.up.railway.app/api/campaign/click', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        campaign_id: 'shekel_april26',
        path_type: 'pageview',  // marks it as page-view, not button click
        lang: currentLang || (document.documentElement.lang || 'he'),
        ref_code: urlParams.get('ref') || null,
        source: source
      })
    }).catch(() => {});
  } catch(e) {}
})();

