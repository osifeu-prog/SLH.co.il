# @SLH_Claude_bot — executor bot for Osif via Telegram
# Copy to .env and fill in real values.

# Telegram bot token from @BotFather for @SLH_Claude_bot
SLH_CLAUDE_BOT_TOKEN=

# Anthropic API key from console.anthropic.com
ANTHROPIC_API_KEY=

# Telegram user ID that's allowed to use this bot (only one allowed)
ADMIN_TELEGRAM_ID=224223270

# Workspace path (inside container or host)
WORKSPACE=/workspace

# Model to use
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Max tokens per response
CLAUDE_MAX_TOKENS=8192

# Enable destructive commands (git push, rm, etc.)  Set to "true" to enable.
ALLOW_DESTRUCTIVE=false
