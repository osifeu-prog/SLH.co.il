async def get_ton_balance(address: str) -> float | None:
    if not TONCENTER_API_KEY:
        logging.error("ط£آ¢أ¢â‚¬إ’ط¥â€™ TONCENTER_API_KEY missing")
        return None
    url = f"{RPC_URL}/getAddressInformation"
    params = {'address': address, 'api_key': TONCENTER_API_KEY}
    logging.info(f"ط¸â€¹ط¹ط›أ¢â‚¬إ“ط·إ’ URL: {url}")
    logging.info(f"ط¸â€¹ط¹ط›أ¢â‚¬إ“ط·إ’ Params: {params}")
    try:
        async with aiohttp.ClientSession() as session:
            async with session.get(url, params=params) as resp:
                logging.info(f"ط¸â€¹ط¹ط›أ¢â‚¬إ“ط·إ’ Response status: {resp.status}")
                if resp.status != 200:
                    logging.error(f"ط£آ¢أ¢â‚¬إ’ط¥â€™ HTTP error {resp.status}")
                    return None
                data = await resp.json()
                logging.info(f"ط¸â€¹ط¹ط›أ¢â‚¬إ“ط·إ’ Response data: {data}")
                if data.get('ok'):
                    balance_nano = int(data['result']['balance'])
                    return balance_nano / 1_000_000_000
                else:
                    logging.error(f"ط£آ¢أ¢â‚¬إ’ط¥â€™ TON Center error: {data}")
                    return None
    except Exception as e:
        logging.exception(f"ط£آ¢أ¢â‚¬إ’ط¥â€™ Exception in get_ton_balance: {e}")
        return None

