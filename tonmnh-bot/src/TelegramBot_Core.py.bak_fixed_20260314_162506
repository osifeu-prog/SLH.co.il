        save_json(ORDERS_FILE, orders)
        await update.message.reply_text(
            f"To purchase {product['name']}, send exactly {price} TON\n"
            f"to address `{USER_WALLET}`\n"
            f"with memo: `{memo}`",
            parse_mode='Markdown'
        )
    except IndexError:
        await update.message.reply_text("Usage: /buy <product_id>")

