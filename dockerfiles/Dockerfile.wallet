FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi \
    uvicorn[standard] \
    python-telegram-bot==20.8 \
    sqlalchemy \
    asyncpg \
    psycopg2-binary \
    pydantic \
    pydantic-settings \
    python-dotenv \
    jinja2 \
    httpx

COPY . .

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080"]
