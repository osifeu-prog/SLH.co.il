{
  "board": "ESP32-2432S028R",
  "alias": "CYD",
  "display": {
    "driver": "ILI9341",
    "width": 240,
    "height": 320,
    "interface": "SPI",
    "spi_frequency_hz": 27000000,
    "pins": {
      "sck": 14,
      "mosi": 13,
      "miso": 12,
      "cs": 15,
      "dc": 2,
      "rst_arduino": -1,
      "rst_micropython": 12,
      "backlight": 21
    }
  },
  "rgb_led": {
    "red": 25,
    "green": 16,
    "blue": 17,
    "active_low": true,
    "pwm_inverted": true
  },
  "buttons": {
    "btn1": 32,
    "btn2": 33,
    "mode": "INPUT_PULLUP"
  },
  "wifi": {
    "ssid": "Beynoni",
    "password": "12345678"
  }
}
