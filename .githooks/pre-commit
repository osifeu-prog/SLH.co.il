#!/usr/bin/env bash
# SLH Spark · pre-commit guard (diff-based only)
# Catches accidental drift reverts. Does NOT read commit message
# (at this stage, the new message isn't written yet — COMMIT_EDITMSG
# still contains the PREVIOUS commit's message). Message-scope check
# lives in .githooks/commit-msg instead.
#
# Install: git config core.hooksPath .githooks
# Bypass: GUARD_CONFIRMED=1 git commit ...
# Docs: ops/HOOKS_IMPROVEMENT_PLAN_20260421.md

set -u

# Thresholds (pre-commit catches only truly catastrophic patterns)
MAX_SINGLE_FILE_NET_DEL=100  # net deletion in one file before blocking
WARN_TOTAL_LINES=300         # warn (but don't block) above this

# Skip if nothing staged
STAGED=$(git diff --cached --numstat)
[ -z "$STAGED" ] && exit 0

total_added=0
total_removed=0
warnings=()
blockers=()

while IFS=$'\t' read -r added removed path; do
    [ "$added" = "-" ] && continue        # binary
    [ -z "$added" ] && continue

    total_added=$((total_added + added))
    total_removed=$((total_removed + removed))

    # Rule: single-file large net deletion → BLOCK (likely drift revert)
    net_del=$((removed - added))
    if [ "$net_del" -gt "$MAX_SINGLE_FILE_NET_DEL" ]; then
        blockers+=("LARGE_DELETE: $path — net -$net_del lines (removed=$removed, added=$added)")
    fi
done <<< "$STAGED"

total_changes=$((total_added + total_removed))

# Rule: total diff oversized → warn only (scope-prefix check is in commit-msg hook)
if [ "$total_changes" -gt "$WARN_TOTAL_LINES" ]; then
    warnings+=("OVERSIZED: $total_changes lines total (threshold: $WARN_TOTAL_LINES). Verify intentional.")
fi

# Bypass clears blockers too
if [ -n "${GUARD_CONFIRMED:-}" ]; then
    all=("${blockers[@]}" "${warnings[@]}")
    if [ "${#all[@]}" -gt 0 ]; then
        echo "⚠️  pre-commit: ${#all[@]} check(s) bypassed via GUARD_CONFIRMED=1" >&2
        printf '  - %s\n' "${all[@]}" >&2
    fi
    exit 0
fi

# Pass-through warnings (non-blocking)
if [ "${#warnings[@]}" -gt 0 ] && [ "${#blockers[@]}" -eq 0 ]; then
    printf '⚠️  pre-commit: %s\n' "${warnings[@]}" >&2
    exit 0
fi

# Block on hard failures
[ "${#blockers[@]}" -eq 0 ] && exit 0

echo "" >&2
echo "🛑 pre-commit — ${#blockers[@]} BLOCKER(s):" >&2
echo "" >&2
for w in "${blockers[@]}"; do
    echo "  • $w" >&2
done
for w in "${warnings[@]}"; do
    echo "  • $w (warning)" >&2
done
echo "" >&2
echo "Review: git diff --cached --stat" >&2
echo "If intentional: GUARD_CONFIRMED=1 git commit ..." >&2
exit 1
