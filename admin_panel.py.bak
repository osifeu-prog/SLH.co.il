"""
SLH AI Spark Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Admin commands. Only admins (auth.is_authorized) may run these.

- /revenue                 Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢ MRR + last 30d revenue + cost + net
- /quota_user <user_id>    Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢ see/set quota for a user
- /set_tier <user_id> <tier> Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢ manual tier upgrade (e.g., for grandfathered users)
- /anthropic_spend         Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢ estimated Anthropic spend last 7/30 days
- /top_users               Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢ top 10 users by AI message count this month
"""
from __future__ import annotations

import logging
from datetime import datetime, timedelta

import aiosqlite
from aiogram import Dispatcher
from aiogram.filters import Command
from aiogram.types import Message

import pricing
import subscriptions

log = logging.getLogger("slh-admin")


def register(dp: Dispatcher, auth_module) -> None:

    @dp.message(Command("revenue"))
    async def cmd_revenue(msg: Message):
        if not auth_module.is_authorized(msg.from_user.id):
            await msg.answer(auth_module.unauthorized_reply_he(msg.from_user.id))
            return
        stats = await subscriptions.usage_stats(window_days=30)
        mrr = await subscriptions.mrr_ils()

        revenue_ils = stats["revenue_ils_cents"] / 100
        anthropic = stats["usage_by_provider"].get("anthropic", {})
        anthropic_cost_usd = anthropic.get("cost_usd_cents", 0) / 100
        anthropic_cost_ils = anthropic_cost_usd * pricing.USD_ILS_RATE
        net_ils = revenue_ils - anthropic_cost_ils

        tiers_str = "\n".join(
            f"  Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢ {tier}: {count}"
            for tier, count in sorted(stats["tier_counts"].items())
        ) or "  (Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â)"

        await msg.answer(
            f"Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢Ã—Â²Ã‚Â²Ã–Â²Ã‚Â° *Revenue Report Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â 30 Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â*\n\n"
            f"*MRR:* `Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å¡Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â{mrr:,.2f}`\n"
            f"*Revenue 30d:* `Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å¡Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â{revenue_ils:,.2f}`\n"
            f"*Anthropic cost 30d:* `Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å¡Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â{anthropic_cost_ils:,.2f}` (${anthropic_cost_usd:,.2f})\n"
            f"*Net profit 30d:* `Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å¡Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â{net_ils:,.2f}`\n\n"
            f"*Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â:*\n{tiers_str}\n\n"
            f"*Messages 30d:*\n"
            + "\n".join(f"  Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢ {p}: {d['messages']}" for p, d in stats["usage_by_provider"].items())
        )

    @dp.message(Command("anthropic_status"))
    async def cmd_anthropic_status(msg: Message):
        """Probe Anthropic key state: auth + balance Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â without printing the key."""
        if not auth_module.is_authorized(msg.from_user.id):
            await msg.answer(auth_module.unauthorized_reply_he(msg.from_user.id))
            return
        import os, httpx
        key = os.getenv("ANTHROPIC_API_KEY", "")
        if not key.startswith("sk-"):
            await msg.answer(
                "Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â²Ã‚Â²Ã–Â²Ã‚Â´ *ANTHROPIC_API_KEY*\nÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â»Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“-sk-.\n"
                "Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¡Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â£ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“-`slh-claude-bot/.env` Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â `docker compose up -d --force-recreate claude-bot`.")
            return
        # Step 1: auth check via /v1/models (free, doesn't consume credit)
        try:
            r = httpx.get(
                "https://api.anthropic.com/v1/models",
                headers={"x-api-key": key, "anthropic-version": "2023-06-01"},
                timeout=10,
            )
            auth_ok = (r.status_code == 200)
        except Exception as e:
            auth_ok = False
            r_text = f"err: {type(e).__name__}"
        # Step 2: tiny balance probe Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â 1-token call. If it 400s with "credit balance",
        # we know there's $0; if it 200s, balance exists.
        try:
            from anthropic import Anthropic
            c = Anthropic(api_key=key)
            c.messages.create(
                model=os.getenv("CLAUDE_MODEL", "claude-sonnet-4-5-20250929"),
                max_tokens=1,
                messages=[{"role": "user", "content": "."}],
            )
            balance_ok = True
            balance_note = "Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â© balance Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Pro tier Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨"
        except Exception as e:
            err = str(e).lower()
            balance_ok = False
            if "credit balance" in err or "credit_balance" in err or "billing" in err:
                balance_note = "$0 balance Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Pro tier Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â€šÂ¬Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“-Groq fallback Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â»Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â»Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â"
            else:
                balance_note = f"err: {type(e).__name__}: {str(e)[:80]}"
        await msg.answer(
            f"Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“ *Anthropic Status*\n"
            f"  auth: {'Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¦' if auth_ok else 'Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â²Ã‚Â²Ã–Â²Ã‚Å’'}\n"
            f"  balance: {'Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¦' if balance_ok else 'Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¡Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â'}\n"
            f"  Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢ {balance_note}"
        )

    @dp.message(Command("anthropic_spend"))
    async def cmd_spend(msg: Message):
        if not auth_module.is_authorized(msg.from_user.id):
            await msg.answer(auth_module.unauthorized_reply_he(msg.from_user.id))
            return
        for window in (1, 7, 30):
            stats = await subscriptions.usage_stats(window_days=window)
            anthropic = stats["usage_by_provider"].get("anthropic", {})
            cost_usd = (anthropic.get("cost_usd_cents", 0)) / 100
            tin = anthropic.get("tokens_in", 0)
            tout = anthropic.get("tokens_out", 0)
            await msg.answer(
                f"Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â²Ã‚Â²Ã–Â²Ã‚Å  *Anthropic Spend Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â {window}d*\n"
                f"  Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢Ã—Â²Ã‚Â²Ã–Â²Ã‚Âµ ${cost_usd:,.2f} (~Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å¡Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â{cost_usd * pricing.USD_ILS_RATE:,.2f})\n"
                f"  Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¥ {tin:,} input tokens\n"
                f"  Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³- {tout:,} output tokens"
            )

    @dp.message(Command("quota_user"))
    async def cmd_quota_user(msg: Message):
        if not auth_module.is_authorized(msg.from_user.id):
            await msg.answer(auth_module.unauthorized_reply_he(msg.from_user.id))
            return
        parts = (msg.text or "").split()
        if len(parts) < 2:
            await msg.answer("Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©: `/quota_user <user_id>`")
            return
        try:
            target_uid = int(parts[1])
        except ValueError:
            await msg.answer("user_id Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¡Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨.")
            return
        sub = await subscriptions.get_or_create(target_uid)
        spec = pricing.TIERS.get(sub.tier, pricing.TIERS["free"])
        cap = spec.monthly_quota or spec.fair_use_cap
        await msg.answer(
            f"Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³- *User {target_uid}*\n"
            f"  Tier: `{sub.tier}` Ã—Â³Ã‚Â²Ã–Â²Ã‚Â²Ã—Â²Ã‚Â²Ã–Â²Ã‚Â· {spec.name_he}\n"
            f"  Used: {sub.messages_used_this_period}/{cap}\n"
            f"  Period: `{sub.current_period_start[:10]}` Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢ `{sub.current_period_end[:10]}`\n"
            f"  Provider: `{sub.payment_provider or 'none'}`"
        )

    @dp.message(Command("grandfather"))
    async def cmd_grandfather(msg: Message):
        """
        Bulk-grant Pro to a user with custom duration. Same effect as /set_tier
        but semantic Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â for early-access promos to community members.

        Usage: /grandfather <user_id> [days=30] [tier=pro]
        """
        if not auth_module.is_authorized(msg.from_user.id):
            await msg.answer(auth_module.unauthorized_reply_he(msg.from_user.id))
            return
        parts = (msg.text or "").split()
        if len(parts) < 2:
            await msg.answer(
                "Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©: `/grandfather <user_id> [days=30] [tier=pro]`\n\n"
                "Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã—â€™Ã¢â‚¬Å¾Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â:\n"
                "  `/grandfather 224223270` Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Pro 30 Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â\n"
                "  `/grandfather 224223270 90` Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â Pro 90 Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â\n"
                "  `/grandfather 224223270 30 vip` Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â VIP 30 Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â"
            )
            return
        try:
            target_uid = int(parts[1])
        except ValueError:
            await msg.answer("user_id Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¡Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨.")
            return
        try:
            days = int(parts[2]) if len(parts) > 2 else 30
        except ValueError:
            days = 30
        tier = parts[3].lower() if len(parts) > 3 else "pro"
        if tier not in pricing.TIERS:
            await msg.answer(f"Tier Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â§Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â£: {tier}. Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢: {', '.join(pricing.TIERS.keys())}")
            return
        if days < 1 or days > 365:
            await msg.answer("days Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â»Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½- 1-365.")
            return

        sub = await subscriptions.upgrade(
            user_id=target_uid,
            tier=tier,
            provider="grandfather",
            payment_id=f"granted_by_{msg.from_user.id}_for_{days}d",
            period_days=days,
        )
        spec = pricing.TIERS[tier]
        await msg.answer(
            f"Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¦ *Grandfathered*\n\n"
            f"User: `{target_uid}`\n"
            f"Tier: *{spec.name_he}* ({tier})\n"
            f"Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â³Ã‚Â·Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¡Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â: {spec.monthly_quota or 'unlimited'} Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â\n"
            f"Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â§Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â: {days} Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â\n"
            f"Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¡Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â: `{sub.current_period_end[:10]}`\n\n"
            f"_Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½- Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢: Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â© Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¡ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â³Ã‚Â·Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢ Pro Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“ {sub.current_period_end[:10]}. "
            f"Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½- /credits Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â§._"
        )

    @dp.message(Command("set_tier"))
    async def cmd_set_tier(msg: Message):
        if not auth_module.is_authorized(msg.from_user.id):
            await msg.answer(auth_module.unauthorized_reply_he(msg.from_user.id))
            return
        parts = (msg.text or "").split()
        if len(parts) < 3:
            await msg.answer("Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©: `/set_tier <user_id> <free|pro|vip|zvk>`")
            return
        try:
            target_uid = int(parts[1])
        except ValueError:
            await msg.answer("user_id Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¡Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨.")
            return
        tier = parts[2].lower()
        if tier not in pricing.TIERS:
            await msg.answer(f"Tier Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â§Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â£. Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â³-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â: {', '.join(pricing.TIERS.keys())}")
            return
        await subscriptions.upgrade(
            user_id=target_uid,
            tier=tier,
            provider="manual",
            payment_id=f"admin_grant_by_{msg.from_user.id}",
        )
        await msg.answer(f"Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¦ User {target_uid} Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â³Ã‚Â·Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å“-{tier}")

    @dp.message(Command("top_users"))
    async def cmd_top(msg: Message):
        if not auth_module.is_authorized(msg.from_user.id):
            await msg.answer(auth_module.unauthorized_reply_he(msg.from_user.id))
            return
        cutoff = (datetime.utcnow() - timedelta(days=30)).isoformat()
        async with aiosqlite.connect(subscriptions.DB_PATH) as db:
            cur = await db.execute(
                "SELECT user_id, COUNT(*), SUM(cost_usd_cents) "
                "FROM ai_usage WHERE created_at >= ? "
                "GROUP BY user_id ORDER BY COUNT(*) DESC LIMIT 10",
                (cutoff,),
            )
            rows = await cur.fetchall()
        if not rows:
            await msg.answer("Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸ Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â© Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â»Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â© Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Å¸Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¿Ã—Â²Ã‚Â²Ã–Â²Ã‚Â½-Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¨Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸.")
            return
        lines = ["Ã—Â³Ã‚Â³Ã–Â²Ã‚Â Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¸Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â²Ã‚Â²Ã–Â²Ã‚Å  *Top 10 Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â©Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â 30 Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Å¾Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¾Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â*\n"]
        for i, (uid, msgs, cost_cents) in enumerate(rows, 1):
            cost_ils = (cost_cents or 0) / 100 * pricing.USD_ILS_RATE
            lines.append(f"{i}. `{uid}` Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â€šÂ¬Ã‚Å¡Ã–Â²Ã‚Â¬Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â {msgs} Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚ÂÃ—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å“Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â²Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Â¢Ã—Â³Ã‚Â³Ã–Â²Ã‚Â³Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â (Ã—Â³Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â€žÂ¢Ã—Â³Ã¢â‚¬â„¢Ã—â€™Ã¢â‚¬Å¡Ã‚Â¬Ã–Â²Ã‚Å¡Ã—Â²Ã‚Â³Ã—â€™Ã¢â€šÂ¬Ã¢â‚¬Â{cost_ils:.2f})")
        await msg.answer("\n".join(lines))

    log.info("admin_panel handlers registered")

